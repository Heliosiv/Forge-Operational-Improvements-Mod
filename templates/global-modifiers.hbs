<div class="po-window po-window-rest" data-tool="global-modifiers" role="region" aria-label="Party Operations Global Modifiers">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">Global Modifiers - Generated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="global-modifiers-back">Back</button>
      <button type="button" class="po-icon-btn" data-action="global-modifiers-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-gm-shell" id="po-panel-global-modifiers">
      {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs" isGlobalModifiers=true}}

      <section class="po-gm-section po-gm-page-intro">
        <div class="po-gm-page-copy">
          <div class="po-gm-page-eyebrow">GM Workspace</div>
          <div class="po-section-title">Global Modifiers</div>
          <div class="po-hint">Review derived party-wide effects, stage custom party overrides, and disable individual modifiers without leaving the runtime.</div>
        </div>
        <div class="po-gm-page-stat-grid" role="list" aria-label="Modifier summary">
          <div class="po-gm-page-stat" role="listitem">
            <span>Active</span>
            <strong>{{globalRows.length}}</strong>
          </div>
        </div>
      </section>

      <div class="po-grid is-operations-layout">
        <div class="po-gm-section">
          <div class="po-section-title">Active Global Modifiers</div>
          <div class="po-hint">Read-only derived modifiers from current operations, weather, and readiness state.</div>
          {{#if hasGlobalRows}}
          {{#each globalRows}}
          <div class="po-op-summary">
            <strong>{{label}}</strong>: {{value}} - Applies to: {{appliesTo}} - {{key}}
          </div>
          {{#if note}}
          <div class="po-op-summary">Note: {{note}}</div>
          {{/if}}
          {{/each}}
          {{else}}
          <div class="po-op-summary">No applied global modifiers.</div>
          {{/if}}
        </div>
      </div>
    </section>
  </div>
</div>
