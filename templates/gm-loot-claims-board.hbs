<div class="po-window po-window-rest" data-tool="gm-loot-claims-board" role="region" aria-label="Party Operations Live Loot Claims">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">Live Loot Claims - Updated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="gm-loot-claims-board-back">Back</button>
      <button type="button" class="po-icon-btn" data-action="gm-loot-claims-board-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-loot-claims-panel">
      <div class="po-section-head-row">
        <div class="po-section-title">Live Claim Board</div>
        {{#if canManageClaims}}
        <button type="button" class="po-btn po-btn-sm is-danger" data-action="archive-loot-claim-run" data-claim-run-id="{{lootClaims.selectedRunId}}" {{#unless lootClaims.canArchiveSelectedRun}}disabled{{/unless}}>Archive Selected Run</button>
        {{/if}}
      </div>

      {{#if lootClaims.hasSelectedRun}}
      {{#if lootClaims.hasMultipleOpenRuns}}
      <label class="po-resource-row po-loot-claims-run-row">
        <span>Claim Run</span>
        <select name="lootClaimRunId" class="po-select" data-action="set-loot-claim-run">
          {{#each lootClaims.runOptions}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      {{/if}}

      <div class="po-loot-claims-summary-grid">
        <div class="po-op-summary"><strong>Status:</strong> {{lootClaims.selectedRunCard.statusLabel}}</div>
        <div class="po-op-summary"><strong>Published:</strong> {{lootClaims.selectedRunCard.publishedAtLabel}} by {{lootClaims.selectedRunCard.publishedBy}}</div>
        <div class="po-op-summary"><strong>Items:</strong> {{lootClaims.itemCount}} | <strong>Claims:</strong> {{lootClaims.claimsLogCount}}</div>
        <div class="po-op-summary po-loot-claim-currency-card">
          <strong>Currency Remaining</strong>
          <div class="po-loot-claim-currency-total">{{lootClaims.currencyRemainingLabel}}</div>
        </div>
        {{#if lootClaims.selectedRunIsArchived}}
        <div class="po-op-summary"><strong>Archived:</strong> {{lootClaims.selectedRunCard.archivedAtLabel}} by {{lootClaims.selectedRunCard.archivedBy}}</div>
        {{/if}}
      </div>

      {{#if lootClaims.selectedRunIsArchived}}
      <div class="po-op-summary">This run is archived. Open run actions are disabled.</div>
      {{#if canManageClaims}}
      <div class="po-op-action-row">
        <button type="button" class="po-btn po-btn-sm is-primary" data-action="unlock-loot-claim-run" data-claim-run-id="{{lootClaims.selectedRunId}}">Unlock Archived Run</button>
      </div>
      {{/if}}
      {{else}}
      {{#if lootClaims.selectedActorClaimedCurrency}}
      <div class="po-op-summary">Selected actor already claimed a currency share.</div>
      {{/if}}
      {{#if lootClaims.hasUnrepresentedPlayers}}
      <div class="po-loot-claims-unrepresented-warning">
        <strong>No character found for:</strong>
        {{#each lootClaims.unrepresentedPlayers}}
        <span class="po-pill" style="border-left: 3px solid {{color}}">{{name}}</span>
        {{/each}}
      </div>
      {{/if}}
      <div class="po-loot-claims-actor-row">
        <div class="po-loot-claims-actor-header">
          <span>Deposit To</span>
          {{#if lootClaims.selectedActorIsStashLike}}
          <span class="po-pill is-accent">Selected Destination: Stash</span>
          {{/if}}
        </div>
        {{#if lootClaims.hasActorGroups}}
        <div role="radiogroup" aria-label="Deposit destination">
          {{#each lootClaims.actorGroups}}
          <div class="po-loot-claims-actor-group">
            <div class="po-loot-claims-actor-group-header">
              <span class="po-loot-claims-actor-group-name" style="border-left: 3px solid {{ownerColor}}">{{ownerName}}</span>
              {{#if isActive}}<span class="po-pill is-success">Online</span>{{else}}<span class="po-pill">Offline</span>{{/if}}
            </div>
            <div class="po-loot-claims-actor-grid">
              {{#each actors}}
              <button
                type="button"
                class="po-loot-claim-actor-card {{#if selected}}is-selected{{/if}} {{#if isStashLike}}is-stash{{/if}}"
                data-action="set-loot-claim-actor"
                data-actor-id="{{id}}"
                role="radio"
                aria-checked="{{#if selected}}true{{else}}false{{/if}}"
                aria-label="Deposit to {{name}}"
              >
                <input type="radio" name="lootClaimActorId" value="{{id}}" {{#if selected}}checked{{/if}} tabindex="-1" aria-hidden="true" />
                <img class="po-loot-claim-actor-thumb" src="{{img}}" alt="{{name}}" loading="lazy" />
                <span class="po-loot-claim-actor-copy">
                  <span class="po-loot-claim-actor-name">{{name}}</span>
                  <span class="po-loot-claim-actor-meta">
                    <span class="po-pill">{{typeLabel}}</span>
                    {{#if isLastUsed}}<span class="po-pill is-success">Last Used</span>{{/if}}
                    {{#if isStashLike}}<span class="po-pill is-accent">Stash</span>{{/if}}
                    {{#if hasCurrencyLabel}}<span class="po-pill po-loot-claim-actor-gold">{{currencyLabel}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="po-loot-claims-actor-grid" role="radiogroup" aria-label="Deposit destination">
          {{#each lootClaims.actorOptions}}
          <button
            type="button"
            class="po-loot-claim-actor-card {{#if selected}}is-selected{{/if}} {{#if isStashLike}}is-stash{{/if}}"
            data-action="set-loot-claim-actor"
            data-actor-id="{{id}}"
            role="radio"
            aria-checked="{{#if selected}}true{{else}}false{{/if}}"
            aria-label="Deposit to {{name}}"
          >
            <input type="radio" name="lootClaimActorId" value="{{id}}" {{#if selected}}checked{{/if}} tabindex="-1" aria-hidden="true" />
            <img class="po-loot-claim-actor-thumb" src="{{img}}" alt="{{name}}" loading="lazy" />
            <span class="po-loot-claim-actor-copy">
              <span class="po-loot-claim-actor-name">{{name}}</span>
              <span class="po-loot-claim-actor-meta">
                <span class="po-pill">{{typeLabel}}</span>
                {{#if isLastUsed}}<span class="po-pill is-success">Last Used</span>{{/if}}
                {{#if isStashLike}}<span class="po-pill is-accent">Stash</span>{{/if}}
                {{#if hasCurrencyLabel}}<span class="po-pill po-loot-claim-actor-gold">{{currencyLabel}}</span>{{/if}}
              </span>
            </span>
          </button>
          {{/each}}
        </div>
        {{/if}}
      </div>
      <div class="po-loot-claims-quick-actions">
        <div class="po-op-summary"><strong>Quick Actions:</strong> Deposit everything to the selected destination, then use the assignment tools if needed.</div>
        <div class="po-op-action-row">
        <button type="button" class="po-btn po-btn-sm is-primary" data-action="claim-all-loot" data-claim-run-id="{{lootClaims.selectedRunId}}" {{#unless lootClaims.canSendEverything}}disabled{{/unless}}>Deposit All</button>
        <button type="button" class="po-btn po-btn-sm" data-action="auto-assign-by-vouch" data-claim-run-id="{{lootClaims.selectedRunId}}" {{#unless lootClaims.canAutoAssignByVouch}}disabled{{/unless}}>Assign by Vouch</button>
        <button type="button" class="po-btn po-btn-sm" data-action="auto-split-items" data-claim-run-id="{{lootClaims.selectedRunId}}" {{#unless lootClaims.canAutoSplitItems}}disabled{{/unless}}>Even-split Items</button>
        </div>
      </div>
      {{#if lootClaims.hasUndoEntries}}
      <div class="po-loot-claims-undo-panel">
        <div class="po-op-summary"><strong>Undo Window (5s)</strong></div>
        <div class="po-op-action-row">
          {{#each lootClaims.undoEntries}}
          <button type="button" class="po-btn po-btn-sm" data-action="undo-loot-claim" data-claim-run-id="{{@root.lootClaims.selectedRunId}}" data-log-id="{{id}}">Undo {{itemName}} ({{undoRemainingSeconds}}s)</button>
          {{/each}}
        </div>
      </div>
      {{/if}}
      {{/if}}

      {{#if lootClaims.hasItems}}
      <div class="po-loot-claims-live-controls">
        <label class="po-resource-row">
          <span>Search Items</span>
          <input type="search" class="po-text-input" value="{{lootClaims.liveSearch}}" placeholder="Search by item name" data-action="set-loot-claims-live-search" />
        </label>
        <label class="po-resource-row">
          <span>Sort</span>
          <select class="po-select" data-action="set-loot-claims-live-sort">
            {{#each lootClaims.liveSortOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
      </div>
      {{#if lootClaims.hasVisibleItems}}
      <div class="po-loot-claim-items-grid">
      {{#each lootClaims.items}}
      <article class="po-op-role-row po-loot-claim-card {{#if requiresRollOff}}is-contested{{/if}}" data-po-item-card="loot-claim-item" data-item-id="{{id}}" data-uuid="{{uuid}}">
        <div class="po-loot-claim-card-head">
          <img class="po-loot-claim-thumb" src="{{img}}" alt="{{name}}" loading="lazy" {{#if canOpen}}data-po-item-open-target="true" title="Double-click to open {{name}}"{{/if}} />
          <div class="po-loot-claim-copy">
            <div class="po-loot-claim-name-row">
              <div class="po-op-role-name">{{name}}</div>
              {{#if hasQuantity}}<span class="po-pill">x{{quantity}}</span>{{/if}}
              {{#if isMajorItem}}<span class="po-pill is-warn">Major Item</span>{{/if}}
            </div>

            <div class="po-loot-claim-tags">
              <span class="po-pill">{{itemType}}</span>
              {{#if hasRarity}}<span class="po-pill">Rarity: {{rarity}}</span>{{/if}}
              {{#if hasItemValue}}<span class="po-pill">Value: {{itemValueLabel}}</span>{{/if}}
              {{#if hasItemWeight}}<span class="po-pill">Weight: {{itemWeightLabel}}</span>{{/if}}
              <span class="po-pill">Source: {{sourceLabel}}</span>
            </div>
          </div>

          <div class="po-loot-claim-side">
            <div class="po-op-role-status">{{itemType}}{{#if hasQuantity}} x{{quantity}}{{/if}}</div>
            {{#if @root.canManageClaims}}
            <label class="po-switch po-loot-claim-major-toggle">
              <input id="po-loot-major-item-{{id}}" name="poLootMajorItem_{{id}}" type="checkbox" data-action="set-loot-major-item" data-item-id="{{id}}" data-claim-run-id="{{claimRunId}}" {{#if isMajorItem}}checked{{/if}} {{#if ../lootClaims.selectedRunIsArchived}}disabled{{/if}} />
              <span>Major Item</span>
            </label>
            {{/if}}
          </div>
        </div>

        <div class="po-op-action-row po-loot-claim-actions">
          <button type="button" class="po-btn po-btn-sm is-primary" data-action="claim-loot-item" data-item-id="{{id}}" data-claim-run-id="{{claimRunId}}" {{#unless canClaimDirect}}disabled{{/unless}}>Assign Item</button>
        </div>
      </article>
      {{/each}}
      </div>
      {{else}}
      <div class="po-op-summary">No items match the current search.</div>
      {{/if}}
      {{else}}
      <div class="po-op-summary">No active claim items in this run.</div>
      {{/if}}

      {{#if lootClaims.claimsLogEntries.length}}
      <details class="po-panel-disclosure po-loot-claim-history-panel" open>
        <summary class="po-panel-disclosure-summary">
          <span class="po-section-title">Run Claim History</span>
          <span class="po-op-summary">{{lootClaims.claimsLogCount}} entries</span>
        </summary>
        <div class="po-panel-disclosure-body">
          <div class="po-op-stack">
            {{#each lootClaims.claimsLogEntries}}
            <div class="po-op-summary {{#if isUndone}}is-muted{{/if}}">
              <strong>{{claimedAtLabel}}</strong> — {{itemName}} → {{actorName}} (by {{claimedByName}}){{#if isUndone}} • Undone {{undoneAtLabel}} by {{undoneByName}}{{/if}}
            </div>
            {{/each}}
          </div>
        </div>
      </details>
      {{/if}}
      {{else}}
      <div class="po-op-summary">No loot claim runs are available yet.</div>
      {{/if}}
    </section>
  </div>
</div>
