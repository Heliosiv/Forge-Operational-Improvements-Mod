<div class="po-window po-window-rest-player" data-tool="rest-watch-player" role="region" aria-label="Party Operations Player View">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">{{#if playerHubSimpleMode}}Player Hub{{else}}Rest Watch (Player){{/if}} - Last updated {{lastUpdatedAt}} by {{lastUpdatedBy}}</div>
    </div>
    <div class="po-context-pill" aria-hidden="true">Player View</div>
    <div class="po-controls">
      <button type="button" class="po-icon-btn" data-action="refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    {{#if playerHubSimpleMode}}
    <section class="po-content po-player-hub-shell">
      {{#if playerActorSelector.hasChoices}}
      <div class="po-player-character-strip" aria-label="Active character">
        <span class="po-player-character-strip-label">Using</span>
        <div class="po-player-character-options">
          {{#each playerActorSelector.options}}
          <button type="button" class="po-player-character-chip {{#if selected}}is-active{{/if}}" data-action="switch-character" data-actor-id="{{id}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">
            {{#if img}}<img src="{{img}}" alt="" />{{/if}}
            <span>{{name}}</span>
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if playerHubFlow.hasCards}}
      <nav class="po-player-hub-nav" role="tablist" aria-label="Player Hub Tabs">
        {{#each playerHubFlow.cards}}
        <button type="button" role="tab" aria-controls="po-player-hub-panel-{{tab}}" tabindex="{{#if selected}}0{{else}}-1{{/if}}" class="po-player-hub-nav-card {{toneClass}} {{#if selected}}is-active{{/if}}" data-action="player-hub-tab" data-tab="{{tab}}" aria-selected="{{#if selected}}true{{else}}false{{/if}}">
          <span class="po-player-hub-nav-label">{{label}}</span>
          <strong class="po-player-hub-nav-value">{{value}}</strong>
          <span class="po-player-hub-nav-detail">{{detail}}</span>
          <span class="po-player-hub-nav-action">{{nextActionLabel}}</span>
          {{#if hasBlockedReason}}<span class="po-player-hub-nav-blocked">{{blockedReason}}</span>{{/if}}
        </button>
        {{/each}}
      </nav>
      {{/if}}

      {{#if playerHubFlow.hasAttention}}
      <section class="po-player-hub-attention {{playerHubFlow.attention.toneClass}}" aria-label="What needs my attention">
        <span>What needs my attention?</span>
        <strong>{{playerHubFlow.attention.nextActionLabel}}</strong>
        <div>{{playerHubFlow.attention.detail}}{{#if playerHubFlow.attention.hasBlockedReason}} - {{playerHubFlow.attention.blockedReason}}{{/if}}</div>
      </section>
      {{/if}}

      {{#if playerHubWatch}}
      {{> "modules/party-operations/templates/partials/rest-watch-player/simple-watch.hbs"}}
      {{/if}}

      {{#if playerHubMarch}}
      {{> "modules/party-operations/templates/partials/rest-watch-player/simple-march.hbs"}}
      {{/if}}

      {{#if playerHubLoot}}
      {{> "modules/party-operations/templates/partials/rest-watch-player/simple-loot.hbs"}}
      {{/if}}

      {{#if playerHubDowntime}}
      {{> "modules/party-operations/templates/partials/rest-watch-player/simple-downtime.hbs"}}
      {{/if}}
    </section>
    {{else}}
    {{> "modules/party-operations/templates/partials/rest-watch-player/classic.hbs"}}
    {{/if}}
  </div>

  <footer class="po-footer">
    <div class="po-footer-text">{{#if playerHubSimpleMode}}Player Hub{{else}}Rest Watch{{/if}}</div>
    <div class="po-footer-text">{{#if playerHubSimpleMode}}{{#if playerHubWatch}}Watch{{/if}}{{#if playerHubMarch}}March{{/if}}{{#if playerHubLoot}}Loot{{/if}}{{#if playerHubDowntime}}Downtime{{/if}}{{else}}Player view{{/if}}</div>
  </footer>
</div>
