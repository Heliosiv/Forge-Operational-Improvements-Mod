<div class="po-window po-window-rest" data-tool="gm-merchants" role="region" aria-label="Party Operations GM Merchants">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">GM Merchants - Generated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="gm-merchants-page-back">Back to Cockpit</button>
      <button type="button" class="po-icon-btn" data-action="gm-merchants-page-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-gm-shell" id="po-panel-gm-merchants-page">
      {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs" isMerchants=true}}

      <section class="po-gm-section po-merchants-hero po-gm-page-intro">
        <div class="po-merchants-hero-copy po-gm-page-copy">
          <div class="po-gm-page-eyebrow">GM Workspace</div>
          {{#if merchants.gm.viewTabCityEditor}}
          <div class="po-section-title">Configured Merchants</div>
          <div class="po-hint">Choose which PC actors can trade, then deploy merchants directly to the live merchant workspace.</div>
          {{/if}}
          {{#if merchants.gm.viewTabWorkspace}}
          <div class="po-section-title">Merchant Workspace</div>
          <div class="po-hint">Pick a merchant preset, name the merchant, and only open advanced stock controls when you need an override.</div>
          {{/if}}
          {{#if merchants.gm.viewTabConfiguredMerchants}}
          <div class="po-section-title">Configured Merchants</div>
          <div class="po-hint">Choose PC actor access on each merchant card, then deploy the merchant to the live workspace.</div>
          {{/if}}
          {{#if merchants.gm.viewTabShopSession}}
          <div class="po-section-title">Shop Session</div>
          <div class="po-hint">Control who can open each merchant, what they can trade, and whether the current roster is live.</div>
          {{/if}}
          <div class="po-op-action-row po-gm-page-actions">
            <button type="button" class="po-btn po-btn-sm is-primary" data-action="merchant-shop-bell">
              <i class="fa-solid fa-bell"></i>
              <span>Open Shops</span>
            </button>
            <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-close" {{#unless merchants.gm.shopSession.isOpen}}disabled{{/unless}}>Close Shops</button>
            <button type="button" class="po-btn po-btn-sm" data-action="merchant-gm-view-tab" data-tab="configured-merchants">Manage Merchants</button>
          </div>
        </div>
        <div class="po-gm-page-stat-grid" role="list" aria-label="Merchant workspace summary">
          <div class="po-gm-page-stat" role="listitem">
            <span>View</span>
            <strong>
              {{#if merchants.gm.viewTabCityEditor}}Location Editor{{/if}}
              {{#if merchants.gm.viewTabWorkspace}}Merchant Workspace{{/if}}
              {{#if merchants.gm.viewTabConfiguredMerchants}}Configured Merchants{{/if}}
              {{#if merchants.gm.viewTabShopSession}}Shop Session{{/if}}
            </strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Configured</span>
            <strong>{{merchants.gm.totalDefinitionCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Source</span>
            <strong>Compendium</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Preset Items</span>
            <strong>{{merchants.gm.sourceTaxonomy.itemCount}}</strong>
          </div>
        </div>
      </section>

      <div id="po-gm-merchants" class="po-gm-section po-merchants-page">
        <input type="hidden" name="merchantId" value="{{merchants.gm.editor.id}}" />
        <div class="po-merchant-workspace">
          <div class="po-tabs po-tabs-sub po-merchant-view-tabs po-gm-subtabs" aria-label="Merchant view toggle">
            <button type="button" class="po-tab {{#if merchants.gm.viewTabWorkspace}}is-active{{/if}}" data-action="merchant-gm-view-tab" data-tab="editor">Build</button>
            <button type="button" class="po-tab {{#if merchants.gm.viewTabConfiguredMerchants}}is-active{{/if}}" data-action="merchant-gm-view-tab" data-tab="configured-merchants">Merchants</button>
          </div>

          <div class="po-merchant-view-panel">
        {{#if merchants.gm.viewTabCityEditor}}
        <div class="po-two-col po-merchant-city-editor-grid">
          <div class="po-col po-merchant-city-editor-column">
            <div class="po-section-title">Location Editor</div>
            <div class="po-hint">Manage the location catalog used for merchant setup and assignment.</div>
            <div class="po-merchant-city-catalog">
              <label class="po-resource-row po-merchant-city-row">
                <span>Location Catalog</span>
                <input type="text" name="merchantCityCatalog" class="po-input" value="{{merchants.gm.cityCatalogInput}}" placeholder="Waterdeep, Baldur's Gate, Neverwinter, Roadside Camp" />
              </label>
              <button type="button" class="po-btn po-btn-sm" data-action="merchant-save-city-catalog">Save Locations</button>
            </div>
          </div>
          <div class="po-col po-merchant-city-editor-column po-merchant-city-catalog-panel">
            <div class="po-section-title">Saved Locations</div>
            <div class="po-op-summary">{{merchants.gm.savedLocationCatalogCount}} location(s)</div>
            {{#if merchants.gm.hasSavedLocationCatalogRows}}
            <div class="po-merchant-city-catalog-list">
              {{#each merchants.gm.savedLocationCatalogRows}}
              <div class="po-merchant-city-catalog-item" data-merchant-location-row data-location="{{value}}">
                <div class="po-merchant-location-card-head">
                  <label class="po-resource-row po-merchant-location-name-row">
                    <span>Location</span>
                    <input type="text" name="merchantCatalogLocationName" class="po-input" value="{{value}}" />
                  </label>
                  <div class="po-op-summary">Status: {{statusLabel}} | {{merchantCount}} merchant(s)</div>
                </div>
                <div class="po-op-action-row po-merchant-location-row-actions">
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-update-location-catalog-entry">Save</button>
                  <button type="button" class="po-btn po-btn-sm is-danger" data-action="merchant-remove-location-catalog-entry">Remove</button>
                </div>
                <div class="po-merchant-location-row-assignment">
                  <label class="po-resource-row po-merchant-location-add-row">
                    <span>Add Merchant</span>
                    <select class="po-select" name="merchantCatalogLocationMerchant">
                      {{#each availableMerchantOptions}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <button
                    type="button"
                    class="po-btn po-btn-sm"
                    data-action="merchant-location-add-merchant"
                    {{#unless hasAvailableMerchantOptions}}disabled{{/unless}}
                  >Add</button>
                </div>
                {{#if hasAssignedMerchantRows}}
                <div class="po-merchant-location-assigned-list">
                  {{#each assignedMerchantRows}}
                  <div class="po-merchant-location-assigned-item">
                    <span>{{name}}{{#if title}} - {{title}}{{/if}}</span>
                    <button
                      type="button"
                      class="po-btn po-btn-sm"
                      data-action="merchant-location-remove-merchant"
                      data-merchant-id="{{id}}"
                    >Remove</button>
                  </div>
                  {{/each}}
                </div>
                {{else}}
                <div class="po-op-summary">No merchants assigned yet.</div>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="po-op-summary">No locations saved yet.</div>
            {{/if}}
          </div>
        </div>
        {{/if}}

        {{#if merchants.gm.viewTabWorkspace}}
        <div class="po-panel-disclosure po-merchant-editor-subsection">
          <div class="po-panel-disclosure-summary">
            <span class="po-section-title">Editing Merchant: {{merchants.gm.editorSelectionLabel}}</span>
            <span class="po-op-summary">{{#if merchants.gm.editorSelectionIsNew}}Draft mode{{else}}Configured merchant loaded{{/if}}</span>
          </div>
          <div class="po-panel-disclosure-body">
            <div class="po-two-col po-merchant-editor-grid">
              <div class="po-col po-merchant-editor-column">
                <div class="po-section-title">Merchant Presets</div>
                <div class="po-hint">Choose the shop preset first, then adjust identity fields only when needed.</div>
                <label class="po-resource-row">
                  <span>Merchant Preset</span>
                  <select class="po-select" name="merchantArchetype" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.archetypeOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <div class="po-op-action-row po-merchant-preset-actions">
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-apply-preset-defaults">Apply Preset Defaults</button>
                </div>
                <div class="po-op-summary">{{merchants.gm.editor.specialtyLabel}}</div>
                <div class="po-op-summary">{{merchants.gm.editor.pricePostureLabel}}</div>
                <div class="po-op-summary">{{merchants.gm.editor.stockCadenceLabel}}</div>
                <label class="po-resource-row">
                  <span>Name</span>
                  <input type="text" name="merchantName" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.name}}" placeholder="Merchant Name" />
                </label>
                <div class="po-op-action-row po-merchant-randomize-actions">
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-randomize-name">Randomize Name + Title</button>
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-randomize-race">Randomize Race</button>
                </div>
                <label class="po-resource-row">
                  <span>Title</span>
                  <select class="po-select" name="merchantTitle" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.titleOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Race</span>
                  <input
                    type="text"
                    class="po-input"
                    name="merchantRace"
                    list="po-merchant-race-options"
                    data-action="merchant-editor-draft-change"
                    value="{{merchants.gm.editor.race}}"
                    placeholder="Human, Elf, Dwarf, or custom"
                  />
                  <datalist id="po-merchant-race-options">
                    {{#each merchants.gm.raceOptions}}
                    <option value="{{value}}">{{label}}</option>
                    {{/each}}
                  </datalist>
                </label>
                <label class="po-resource-row">
                  <span>Image</span>
                  <input type="text" name="merchantImg" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.img}}" placeholder="icons/svg/item-bag.svg" />
                </label>
                <label class="po-resource-row">
                  <span>Access Mode</span>
                  <select class="po-select" name="merchantAccessMode" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.accessModeOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Manual Source Tuning</span>
                  <input type="checkbox" name="merchantCustomMode" data-action="merchant-editor-draft-change" {{#if merchants.gm.editor.customMode}}checked{{/if}} />
                </label>
                <div class="po-op-summary">{{#if merchants.gm.editor.customMode}}Expert override active. Compendium and rarity controls below are now driving stock.{{else}}Archetype-driven stock is active from the compendium. Leave manual tuning off for simple shop generation.{{/if}}</div>
                <details class="po-panel-disclosure po-merchant-advanced-stock" {{#if merchants.gm.editor.customMode}}open{{/if}}>
                  <summary class="po-panel-disclosure-summary">
                    <span class="po-section-title">Advanced Stock Overrides</span>
                    <span class="po-op-summary">Compendium pool and rarity controls</span>
                  </summary>
                  <div class="po-panel-disclosure-body">
                <label class="po-resource-row">
                  <span>Stock Source Type</span>
                  <select class="po-select" name="merchantSourceType" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.sourceTypeOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <div class="po-resource-row po-merchant-source-row">
                  <span>Stock Compendium</span>
                  <div class="po-merchant-source-picker">
                    {{#if merchants.gm.hasSourceRefSelectableOptions}}
                    <div class="po-merchant-source-filter-bar">
                      <label class="po-merchant-source-filter-field">
                        <span>Filter Compendium</span>
                        <input
                          type="search"
                          name="merchantSourceFilter"
                          class="po-input"
                          value="{{merchants.gm.sourcePackFilter}}"
                          placeholder="Type to filter compendium items"
                          autocomplete="off"
                          spellcheck="false"
                          data-merchant-source-filter
                        />
                      </label>
                      <button
                        type="button"
                        class="po-btn po-btn-sm"
                        data-action="merchant-clear-source-filter"
                        data-merchant-source-filter-clear
                        {{#unless merchants.gm.sourcePackFilterActive}}disabled{{/unless}}
                      >Clear</button>
                    </div>
                    <div class="po-op-summary">
                      <span data-merchant-source-ref-selected-count>{{merchants.gm.sourceRefSelectedCount}}</span>
                      selected.
                      <span data-merchant-source-ref-visible-count>{{merchants.gm.sourceRefOptionCount}}</span>
                      available.
                    </div>
                    {{#if merchants.gm.sourceRefIsFolderTree}}
                    <div class="po-op-summary">Compendium stock is the supported source for merchant generation.</div>
                    {{/if}}
                    <div class="po-merchant-source-list {{#if merchants.gm.sourceRefIsFolderTree}}is-folder-tree{{/if}}" data-po-scroll-preserve="merchant-source-ref-list">
                      {{#each merchants.gm.sourceRefSelectableOptions}}
                      <label
                        class="po-merchant-source-option {{#if disabled}}is-disabled{{/if}} {{#if ../merchants.gm.sourceRefIsFolderTree}}is-folder-node{{/if}}"
                        data-merchant-source-option
                        data-search="{{searchText}} {{label}} {{value}}"
                        data-source-filter-match="{{#if matchesActiveFilters}}1{{else}}0{{/if}}"
                        {{#if ../merchants.gm.sourceRefIsFolderTree}}style="--po-source-depth: {{depth}};"{{/if}}
                      >
                        <input type="checkbox" name="merchantSourceRef" value="{{value}}" data-action="merchant-editor-draft-change" {{#if selected}}checked{{/if}} {{#if disabled}}disabled{{/if}} />
                        {{#if ../merchants.gm.sourceRefIsFolderTree}}
                        <span class="po-merchant-source-option-copy">
                          <span class="po-merchant-source-option-title-row">
                            <span class="po-merchant-source-option-title">{{label}}</span>
                            {{#if hasChildren}}<span class="po-pill">{{descendantCountLabel}}</span>{{/if}}
                          </span>
                          {{#if hasParent}}<span class="po-merchant-source-option-meta">{{parentPathLabel}}</span>{{/if}}
                        </span>
                        {{else}}
                        <span>{{label}}</span>
                        {{/if}}
                      </label>
                      {{/each}}
                    </div>
                    <div class="po-op-summary" data-merchant-source-ref-empty hidden>No stock sources match this filter.</div>
                    {{else}}
                    <div class="po-op-summary">{{merchants.gm.sourceRefHintLabel}}</div>
                    {{/if}}
                  </div>
                </div>
                    <label class="po-resource-row">
                      <span>Value Strictness</span>
                      <input type="number" min="50" max="300" step="10" name="merchantValueStrictness" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.valueStrictness}}" />
                    </label>
                    <div class="po-resource-row po-merchant-rarity-row">
                      <span>Rarity Stock Weights</span>
                      <div class="po-op-action-row po-merchant-rarity-grid">
                    <label class="po-merchant-range-option">
                      <span><strong>Common</strong><em>{{merchants.gm.editor.rarityWeightCommon}}</em></span>
                      <input type="range" min="0" max="100" step="1" name="merchantRarityWeightCommon" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityWeightCommon}}" />
                    </label>
                    <label class="po-merchant-range-option">
                      <span><strong>Uncommon</strong><em>{{merchants.gm.editor.rarityWeightUncommon}}</em></span>
                      <input type="range" min="0" max="100" step="1" name="merchantRarityWeightUncommon" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityWeightUncommon}}" />
                    </label>
                    <label class="po-merchant-range-option">
                      <span><strong>Rare</strong><em>{{merchants.gm.editor.rarityWeightRare}}</em></span>
                      <input type="range" min="0" max="100" step="1" name="merchantRarityWeightRare" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityWeightRare}}" />
                    </label>
                    <label class="po-merchant-range-option">
                      <span><strong>Very Rare</strong><em>{{merchants.gm.editor.rarityWeightVeryRare}}</em></span>
                      <input type="range" min="0" max="100" step="1" name="merchantRarityWeightVeryRare" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityWeightVeryRare}}" />
                    </label>
                    <label class="po-merchant-range-option">
                      <span><strong>Legendary</strong><em>{{merchants.gm.editor.rarityWeightLegendary}}</em></span>
                      <input type="range" min="0" max="100" step="1" name="merchantRarityWeightLegendary" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityWeightLegendary}}" />
                    </label>
                      </div>
                    </div>
                  </div>
                </details>
              </div>

              <div class="po-col po-merchant-editor-column">
                <div class="po-section-title">Trade Rules</div>
                <div class="po-hint">These are the high-value controls that shape the storefront: pricing, buyback lane, stock size, and scarcity.</div>
                <label class="po-resource-row">
                  <span>Markup Percent</span>
                  <input type="number" min="0" max="1000" step="0.01" name="merchantMarkupPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.buyMarkupPercent}}" />
                </label>
                <label class="po-resource-row">
                  <span>Sell Rate Percent</span>
                  <input type="number" min="0" max="1000" step="0.01" name="merchantSellRatePercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.sellRatePercent}}" />
                </label>
                <div class="po-panel-disclosure po-merchant-price-scale">
                  <div class="po-panel-disclosure-summary">
                    <span class="po-section-title">Rarity Prices</span>
                    <span class="po-op-summary">Base item price by rarity</span>
                  </div>
                  <div class="po-panel-disclosure-body">
                    <div class="po-resource-row po-merchant-rarity-row">
                      <span>Buy Price Multipliers</span>
                      <div class="po-op-action-row po-merchant-rarity-grid">
                        <label class="po-merchant-range-option">
                          <span><strong>Common</strong><em>{{merchants.gm.editor.rarityPriceCommonPercent}}%</em></span>
                          <input type="range" min="25" max="500" step="5" name="merchantRarityPriceCommonPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityPriceCommonPercent}}" />
                        </label>
                        <label class="po-merchant-range-option">
                          <span><strong>Uncommon</strong><em>{{merchants.gm.editor.rarityPriceUncommonPercent}}%</em></span>
                          <input type="range" min="25" max="500" step="5" name="merchantRarityPriceUncommonPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityPriceUncommonPercent}}" />
                        </label>
                        <label class="po-merchant-range-option">
                          <span><strong>Rare</strong><em>{{merchants.gm.editor.rarityPriceRarePercent}}%</em></span>
                          <input type="range" min="25" max="500" step="5" name="merchantRarityPriceRarePercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityPriceRarePercent}}" />
                        </label>
                        <label class="po-merchant-range-option">
                          <span><strong>Very Rare</strong><em>{{merchants.gm.editor.rarityPriceVeryRarePercent}}%</em></span>
                          <input type="range" min="25" max="500" step="5" name="merchantRarityPriceVeryRarePercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityPriceVeryRarePercent}}" />
                        </label>
                        <label class="po-merchant-range-option">
                          <span><strong>Legendary</strong><em>{{merchants.gm.editor.rarityPriceLegendaryPercent}}%</em></span>
                          <input type="range" min="25" max="500" step="5" name="merchantRarityPriceLegendaryPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.rarityPriceLegendaryPercent}}" />
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
                <label class="po-resource-row">
                  <span>Buy from Players</span>
                  <input type="checkbox" name="merchantSellEnabled" data-action="merchant-editor-draft-change" {{#if merchants.gm.editor.sellEnabled}}checked{{/if}} />
                </label>
                <label class="po-resource-row">
                  <span>Cash On Hand (gp)</span>
                  <input type="number" min="0" max="1000000" step="1" name="merchantCashOnHandGp" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.cashOnHandGp}}" />
                </label>
                <label class="po-resource-row">
                  <span>Scarcity</span>
                  <select class="po-select" name="merchantScarcity" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.scarcityOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Stock Rows</span>
                  <input type="number" min="1" max="100" step="1" name="merchantStockCount" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.stockCount}}" />
                </label>
                <label class="po-resource-row">
                  <span>Target Stock Value (gp)</span>
                  <input type="number" min="0" max="1000000" step="1" name="merchantTargetValueGp" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.targetValueGp}}" />
                </label>
                <label class="po-resource-row">
                  <span>Barter Enabled</span>
                  <input type="checkbox" name="merchantBarterEnabled" data-action="merchant-editor-draft-change" {{#if merchants.gm.editor.barterEnabled}}checked{{/if}} />
                </label>
                <label class="po-resource-row">
                  <span>Barter DC</span>
                  <input type="number" min="1" max="40" step="1" name="merchantBarterDc" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.barterDc}}" />
                </label>
                <label class="po-resource-row">
                  <span>Barter Ability</span>
                  <select class="po-select" name="merchantBarterAbility" data-action="merchant-editor-draft-change">
                    {{#each merchants.gm.barterAbilityOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <div class="po-op-summary">Passing or failing by 5 or more doubles the barter adjustment.</div>
                <label class="po-resource-row">
                  <span>Success Buy Price %</span>
                  <input type="number" min="-1000" max="1000" step="1" name="merchantBarterSuccessBuyModifierPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.barterSuccessBuyModifierPercent}}" />
                </label>
                <label class="po-resource-row">
                  <span>Success Sell Value %</span>
                  <input type="number" min="-1000" max="1000" step="1" name="merchantBarterSuccessSellModifierPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.barterSuccessSellModifierPercent}}" />
                </label>
                <label class="po-resource-row">
                  <span>Failure Buy Price %</span>
                  <input type="number" min="-1000" max="1000" step="1" name="merchantBarterFailureBuyModifierPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.barterFailureBuyModifierPercent}}" />
                </label>
                <label class="po-resource-row">
                  <span>Failure Sell Value %</span>
                  <input type="number" min="-1000" max="1000" step="1" name="merchantBarterFailureSellModifierPercent" class="po-input" data-action="merchant-editor-draft-change" value="{{merchants.gm.editor.barterFailureSellModifierPercent}}" />
                </label>
                <div class="po-resource-row">
                  <span>Buyback</span>
                  <div class="po-op-summary">{{merchants.gm.buybackTypeSummary}}</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        {{/if}}

        {{#if merchants.gm.viewTabHasEditorToolbar}}
        <div class="po-controls po-merchant-toolbar">
          <button type="button" class="po-btn" data-action="merchant-create-starters">Create Starters</button>
          <button type="button" class="po-btn" data-action="merchant-new">New</button>
          <button type="button" class="po-btn is-primary" data-action="merchant-save">Save</button>
          <button type="button" class="po-btn" data-action="merchant-refresh-stock" data-merchant-id="{{merchants.gm.editor.id}}">Refresh Stock</button>
          <button type="button" class="po-btn" data-action="merchant-refresh-all-stock">Refresh All Stock</button>
          <button type="button" class="po-btn" data-action="merchant-open-actor" data-merchant-id="{{merchants.gm.editor.id}}">Open Actor</button>
          <button type="button" class="po-btn is-danger" data-action="merchant-delete" data-merchant-id="{{merchants.gm.editor.id}}">Delete</button>
        </div>
        {{/if}}

        {{#if merchants.gm.viewTabConfiguredMerchants}}
        <section class="po-panel-disclosure po-gm-advanced-disclosure po-merchant-configured-section">
          <div class="po-panel-disclosure-summary">
            <span class="po-section-title">Configured Merchants</span>
            <span class="po-op-summary">{{merchants.gm.filteredDefinitionCount}} shown / {{merchants.gm.totalDefinitionCount}} total</span>
          </div>
          <div class="po-panel-disclosure-body">
            <div class="po-merchant-session-inline">
              <div class="po-merchant-session-brief-row">
                <div class="po-op-summary">Workspace: <strong>{{merchants.gm.shopSession.statusLabel}}</strong></div>
                <div class="po-op-summary">Audience: {{merchants.gm.shopSession.selectedSummary}}</div>
                <div class="po-op-summary">Live merchants: {{merchants.gm.shopSession.tradableCount}} / {{merchants.gm.shopSession.totalMerchantCount}}</div>
                <div class="po-op-action-row po-merchant-session-toolbar">
                  <button type="button" class="po-btn po-btn-sm is-primary" data-action="merchant-shop-bell">
                    <i class="fa-solid fa-bell"></i>
                    <span>Ring Bell</span>
                  </button>
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-close" {{#unless merchants.gm.shopSession.isOpen}}disabled{{/unless}}>Close</button>
                </div>
              </div>
              <label class="po-merchant-shop-player-toggle po-merchant-restrict-toggle">
                <input type="checkbox" data-action="merchant-shop-restrict-toggle" {{#if merchants.gm.shopSession.restrictToSelected}}checked{{/if}} />
                <span>Restrict to selected players</span>
              </label>
              {{#if merchants.gm.shopSession.hasPlayerRows}}
              <div class="po-op-action-row po-merchant-session-actions">
                <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-player-all">All Players</button>
                <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-player-none">Clear Players</button>
              </div>
              <div class="po-merchant-shop-player-grid po-merchant-shop-player-grid-inline">
                {{#each merchants.gm.shopSession.playerRows}}
                <div class="po-merchant-shop-player-row">
                  <label class="po-merchant-shop-player-toggle">
                    <input type="checkbox" data-action="merchant-shop-player-toggle" data-user-id="{{userId}}" {{#if selected}}checked{{/if}} />
                    <span>{{userName}}{{#unless isActive}} (Offline){{/unless}}</span>
                  </label>
                  <label class="po-resource-row po-merchant-shop-player-location">
                    <span>Location</span>
                    <select class="po-select" data-action="merchant-shop-player-location" data-user-id="{{userId}}">
                      {{#each locationOptions}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </label>
                </div>
                {{/each}}
              </div>
              {{else}}
              <div class="po-op-summary">No non-GM players found in this world.</div>
              {{/if}}
            </div>
            <div class="po-merchant-collection-filters po-merchant-filter-grid">
              <label class="po-resource-row">
                <span>Search</span>
                <input
                  type="text"
                  class="po-input"
                  data-action="merchant-gm-filter-change"
                  data-filter-key="search"
                  value="{{merchants.gm.collectionFilterSearch}}"
                  placeholder="Filter by name or title"
                />
              </label>
              <label class="po-resource-row">
                <span>Access</span>
                <select class="po-select" data-action="merchant-gm-filter-change" data-filter-key="access">
                  {{#each merchants.gm.collectionFilterAccessOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="po-resource-row">
                <span>Stock</span>
                <select class="po-select" data-action="merchant-gm-filter-change" data-filter-key="stock">
                  {{#each merchants.gm.collectionFilterStockOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
            </div>
            <div class="po-op-action-row po-merchant-filter-reset-row">
              <button type="button" class="po-btn po-btn-sm" data-action="merchant-gm-filter-reset">Reset Filters</button>
              <button type="button" class="po-btn po-btn-sm" data-action="merchant-refresh-all-stock">Refresh All Stock</button>
              <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-tradable-none">Deselect All Merchants</button>
            </div>
            <div class="po-gm-loot-summary-grid po-merchant-availability-dashboard" role="list" aria-label="Merchant availability dashboard">
              <div class="po-gm-loot-summary-chip" role="listitem"><span>Workspace</span><strong>{{#if merchants.gm.availabilityDashboard.shopOpen}}Open{{else}}Closed{{/if}}</strong></div>
              <div class="po-gm-loot-summary-chip" role="listitem"><span>Live</span><strong>{{merchants.gm.availabilityDashboard.liveCount}}</strong></div>
              <div class="po-gm-loot-summary-chip" role="listitem"><span>Stocked</span><strong>{{merchants.gm.availabilityDashboard.stockedCount}}</strong></div>
              <div class="po-gm-loot-summary-chip" role="listitem"><span>Refresh Due</span><strong>{{merchants.gm.availabilityDashboard.staleCount}}</strong></div>
              <div class="po-gm-loot-summary-chip" role="listitem"><span>Empty</span><strong>{{merchants.gm.availabilityDashboard.emptyCount}}</strong></div>
            </div>
            <div class="po-op-summary">{{merchants.gm.availabilityDashboard.summaryLabel}}</div>
            {{#if merchants.gm.hasDefinitions}}
            {{#if merchants.gm.hasFilteredDefinitions}}
            <div class="po-merchant-definition-list">
              {{#each merchants.gm.definitions}}
              <article class="po-merchant-row {{#if selectedForEdit}}is-editing{{/if}}" data-merchant-id="{{id}}">
                <button type="button" class="po-merchant-row-main" data-action="merchant-edit" data-merchant-id="{{id}}">
                  <span class="po-merchant-row-name">{{name}}</span>
                  <span class="po-merchant-row-subtitle">{{#if title}}{{title}} | {{/if}}{{archetypeLabel}} | {{raceLabel}}</span>
                </button>
                <div class="po-merchant-row-metrics">
                  <span class="po-pill po-merchant-definition-summary-status {{#if shopTradable}}is-tradable{{else}}is-disabled{{/if}}">Shop {{shopTradableLabel}}</span>
                  <span class="po-pill">{{availabilityStatusLabel}}</span>
                  <span class="po-pill {{stockFreshnessToneClass}}">{{stockItemCount}} stock - {{stockFreshnessLabel}}</span>
                  <span class="po-pill">{{accessModeLabel}}</span>
                  <span class="po-pill">{{offerTagSummary}}</span>
                </div>
                <div class="po-merchant-row-actions">
                  <button
                    type="button"
                    class="po-btn po-btn-sm {{#if availableNow}}is-primary{{/if}}"
                    data-action="merchant-make-available-now"
                    data-merchant-id="{{id}}"
                    data-available="{{#if availableNow}}false{{else}}true{{/if}}"
                    title="{{availabilityActionHint}}"
                  >
                    {{#if availableNow}}Show On{{else}}Show Off{{/if}}
                  </button>
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-shop-bell" title="Ring dinner bell for the current live shop list"><i class="fa-solid fa-bell"></i></button>
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-refresh-stock" data-merchant-id="{{id}}">Refresh</button>
                  <button type="button" class="po-btn po-btn-sm" data-action="merchant-open-actor" data-merchant-id="{{id}}">Actor</button>
                  <button type="button" class="po-btn po-btn-sm is-danger" data-action="merchant-delete" data-merchant-id="{{id}}">Delete</button>
                </div>
              </article>
              {{/each}}
            </div>
            {{else}}
            <div class="po-op-summary">No merchants matched your filters.</div>
            {{/if}}
            {{else}}
            <div class="po-op-summary">No merchants configured yet.</div>
            {{/if}}
          </div>
        </section>
        {{/if}}
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
