<div class="po-window po-window-rest" data-tool="gm-factions" role="region" aria-label="Party Operations GM Factions">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">GM Factions - Generated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="gm-factions-page-back">Back</button>
      <button type="button" class="po-icon-btn" data-action="gm-factions-page-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-gm-shell" id="po-panel-gm-factions-page">
      {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs" isFactions=true}}

      <section class="po-gm-section po-gm-page-intro">
        <div class="po-gm-page-copy">
          <div class="po-gm-page-eyebrow">GM Workspace</div>
          <div class="po-section-title">Faction Control</div>
          <div class="po-hint">Manage the full faction ledger here, then decide which factions and notes are projected into the shared Operations view.</div>
        </div>
        <div class="po-gm-page-stat-grid" role="list" aria-label="Faction workspace summary">
          <div class="po-gm-page-stat" role="listitem">
            <span>Tracked</span>
            <strong>{{operations.reputation.totalCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Revealed</span>
            <strong>{{operations.reputation.revealedCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Hidden</span>
            <strong>{{operations.reputation.hiddenCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Allied</span>
            <strong>{{operations.reputation.highStandingCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Hostile</span>
            <strong>{{operations.reputation.hostileCount}}</strong>
          </div>
          <div class="po-gm-page-stat" role="listitem">
            <span>Custom</span>
            <strong>{{operations.reputation.customCount}}</strong>
          </div>
        </div>
      </section>

      <div id="po-gm-factions" class="po-gm-section po-reputation-panel">
        <div class="po-reputation-toolbar">
          <div>
            <div class="po-section-title">Faction Ledger</div>
            <div class="po-hint">Filters apply to the full GM ledger. Hidden factions stay out of Operations until you reveal them.</div>
          </div>
          <button type="button" class="po-btn po-btn-sm" data-action="show-reputation-brief">Show GM Reputation Brief</button>
        </div>

        <div class="po-op-role-row po-reputation-filters">
          <label class="po-resource-row">
            <span>Filter</span>
            <input type="text" class="po-input" data-action="set-reputation-filter-keyword" value="{{operations.reputation.filters.keyword}}" placeholder="Search faction, notes, standing" />
          </label>
          <label class="po-resource-row">
            <span>Standing</span>
            <select class="po-select" data-action="set-reputation-filter-standing">
              {{#each operations.reputation.filters.standingOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <button type="button" class="po-btn po-btn-sm" data-action="clear-reputation-filters">Clear Filters</button>
        </div>

        <details class="po-op-role-row po-reputation-gm-tools po-reputation-builder">
          <summary class="po-reputation-list-summary">
            <div class="po-reputation-card-title">
              <div class="po-op-role-name">Faction Builder</div>
              <div class="po-reputation-card-subtitle">Create a faction with GM notes, linked players, and tracked player-driven standing shifts.</div>
            </div>
            <div class="po-op-role-status po-reputation-standing-pill">Standing {{operations.reputation.builder.score}} | {{operations.reputation.builder.access}}</div>
          </summary>
          <div class="po-reputation-expanded-body">
            <div class="po-reputation-builder-grid">
            <label class="po-resource-row">
              <span>Faction Name</span>
              <input type="text" class="po-input" data-action="set-reputation-builder-field" data-field="label" value="{{operations.reputation.builder.label}}" placeholder="e.g., Black Salt Consortium" />
            </label>
            <label class="po-resource-row">
              <span>Type / Category</span>
              <input type="text" class="po-input" data-action="set-reputation-builder-field" data-field="category" value="{{operations.reputation.builder.category}}" placeholder="Guild, court, cult, militia..." />
            </label>
            <label class="po-resource-row">
              <span>Represents / Sphere</span>
              <input type="text" class="po-input" data-action="set-reputation-builder-field" data-field="represents" value="{{operations.reputation.builder.represents}}" placeholder="What influence or domain this faction covers" />
            </label>
            <label class="po-resource-row">
              <span>Linked Player</span>
              <select class="po-select" data-action="set-reputation-builder-field" data-field="linkedActorId">
                {{#each operations.reputation.builder.actorOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label class="po-resource-row">
              <span>Starting Standing (-5 to +5)</span>
              <input type="number" min="-5" max="5" step="1" class="po-input" data-action="set-reputation-builder-field" data-field="score" value="{{operations.reputation.builder.score}}" />
            </label>
            </div>
          <label class="po-resource-row po-notes-row-lg">
            <span>GM Summary</span>
            <textarea class="po-input" rows="4" data-action="set-reputation-builder-field" data-field="summary" placeholder="What the faction is, what it wants, and why the party cares about it.">{{operations.reputation.builder.summary}}</textarea>
          </label>
          <label class="po-resource-row po-notes-row-lg">
            <span>Current GM Note</span>
            <textarea class="po-input" rows="4" data-action="set-reputation-builder-field" data-field="note" placeholder="Current situation, leverage, tensions, or next expected outcome.">{{operations.reputation.builder.note}}</textarea>
          </label>
          <div class="po-op-summary">New custom factions start hidden from the shared Operations reputation view until you reveal them on the card below.</div>
          <div class="po-reputation-player-impact-section">
            <div class="po-reputation-inline-head">
              <div>
                <div class="po-section-title">Player Influence</div>
                <div class="po-op-summary">Track the current faction increases or decreases attached to specific player characters.</div>
              </div>
              <div class="po-reputation-log-meta">
                <span class="po-reputation-log-chip po-reputation-impact-total {{operations.reputation.builder.playerImpactToneClass}}">Current Total {{operations.reputation.builder.playerImpactTotalLabel}}</span>
                <span class="po-reputation-log-chip">{{operations.reputation.builder.playerImpactCount}} linked entries</span>
              </div>
            </div>
            <div class="po-reputation-player-impact-list">
              {{#each operations.reputation.builder.playerImpacts}}
              <div class="po-reputation-player-impact-row">
                <label class="po-resource-row">
                  <span>Player</span>
                  <select class="po-select" data-action="set-reputation-builder-impact" data-impact-id="{{id}}" data-field="actorId">
                    {{#each actorOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Delta</span>
                  <input type="number" min="-5" max="5" step="1" class="po-input" data-action="set-reputation-builder-impact" data-impact-id="{{id}}" data-field="delta" value="{{delta}}" />
                </label>
                <label class="po-resource-row po-notes-row-lg">
                  <span>Reason / Note</span>
                  <textarea class="po-input" rows="2" data-action="set-reputation-builder-impact" data-impact-id="{{id}}" data-field="note" placeholder="Why this player is moving the faction up or down.">{{note}}</textarea>
                </label>
                <button type="button" class="po-btn po-btn-sm is-danger" data-action="remove-reputation-builder-impact" data-impact-id="{{id}}">Remove</button>
              </div>
              {{/each}}
            </div>
            <div class="po-op-action-row">
              <button type="button" class="po-btn po-btn-sm" data-action="add-reputation-builder-impact">Add Player Influence</button>
            </div>
          </div>
          <div class="po-op-action-row">
            <button type="button" class="po-btn po-btn-sm is-primary" data-action="add-reputation-faction">Create Faction</button>
            <button type="button" class="po-btn po-btn-sm" data-action="clear-reputation-builder">Clear Builder</button>
          </div>
          </div>
        </details>

        {{#if operations.reputation.visibleCount}}
        <div class="po-reputation-list">
          {{#each operations.reputation.filteredFactions}}
          <details class="po-op-role-row po-reputation-faction-card po-reputation-list-row {{standingClass}}" data-faction="{{id}}" data-standing="{{score}}" style="{{standingStyle}}">
            <summary class="po-reputation-list-summary">
              <div class="po-reputation-list-main">
                <div class="po-reputation-list-title-row">
                  <span class="po-op-role-name">{{label}}</span>
                  <span class="po-reputation-card-subtitle">{{#if isCore}}Core{{else}}Custom{{/if}}</span>
                </div>
                <div class="po-reputation-list-meta">
                  <span>{{categoryLabel}}</span>
                  {{#if hasRepresents}}<span>{{represents}}</span>{{/if}}
                  {{#if hasLinkedActor}}<span>{{linkedActorName}}</span>{{/if}}
                </div>
                <div class="po-reputation-list-note">
                  {{#if hasOperationsNote}}{{operationsNote}}{{else}}{{#if hasOperationsSummary}}{{operationsSummary}}{{else}}{{#if hasSummary}}{{summary}}{{else}}No faction note yet.{{/if}}{{/if}}{{/if}}
                </div>
              </div>
              <div class="po-reputation-list-status">
                <span class="po-op-role-status po-reputation-standing-pill">Standing {{score}} | {{access}}</span>
                <span class="po-reputation-log-chip po-reputation-impact-total {{playerImpactToneClass}}">Player {{playerImpactTotalLabel}}</span>
                <span class="po-reputation-log-chip">{{operationsVisibilityLabel}}</span>
              </div>
            </summary>

            <div class="po-reputation-expanded-body">
              <div class="po-reputation-detail-chips">
                <span class="po-reputation-log-chip">Type: {{categoryLabel}}</span>
                {{#if hasRepresents}}<span class="po-reputation-log-chip">Represents: {{represents}}</span>{{/if}}
                {{#if hasLinkedActor}}<span class="po-reputation-log-chip">Linked Player: {{linkedActorName}}</span>{{/if}}
                <span class="po-reputation-log-chip po-reputation-impact-total {{playerImpactToneClass}}">Player Delta {{playerImpactTotalLabel}}</span>
                <span class="po-reputation-log-chip">{{operationsVisibilityLabel}}</span>
              </div>

            <div class="po-reputation-detail-grid">
              {{#unless isCore}}
              <label class="po-resource-row">
                <span>Faction Name</span>
                <input type="text" class="po-input" data-action="set-reputation-label" data-faction="{{id}}" value="{{label}}" />
              </label>
              {{/unless}}
              <label class="po-resource-row">
                <span>Type / Category</span>
                <input type="text" class="po-input" data-action="set-reputation-detail" data-faction="{{id}}" data-field="category" value="{{category}}" placeholder="Guild, house, cult, militia..." />
              </label>
              <label class="po-resource-row">
                <span>Represents / Sphere</span>
                <input type="text" class="po-input" data-action="set-reputation-detail" data-faction="{{id}}" data-field="represents" value="{{represents}}" placeholder="What influence or domain this faction covers" />
              </label>
              <label class="po-resource-row">
                <span>Linked Player</span>
                <select class="po-select" data-action="set-reputation-detail" data-faction="{{id}}" data-field="linkedActorId">
                  {{#each linkedActorOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="po-resource-row">
                <span>Standing (-5 to +5)</span>
                <input type="number" min="-5" max="5" step="1" class="po-input" data-action="set-reputation-score" data-faction="{{id}}" value="{{score}}" />
              </label>
            </div>

            <div class="po-op-action-row po-reputation-score-actions">
              <button type="button" class="po-btn po-btn-sm" data-action="adjust-reputation-score" data-faction="{{id}}" data-delta="-1">Lower</button>
              <button type="button" class="po-btn po-btn-sm" data-action="adjust-reputation-score" data-faction="{{id}}" data-delta="1">Raise</button>
            </div>

            <label class="po-resource-row po-notes-row-lg">
              <span>GM Summary</span>
              <textarea class="po-input" rows="3" data-action="set-reputation-detail" data-faction="{{id}}" data-field="summary" placeholder="What this faction is, what it wants, and how it fits into the campaign.">{{summary}}</textarea>
            </label>
            <label class="po-resource-row po-notes-row-lg">
              <span>Current GM Note</span>
              <textarea class="po-input po-reputation-note" rows="5" data-action="set-reputation-note" data-faction="{{id}}" placeholder="Describe what happened, what changed, and what the party can expect next.">{{note}}</textarea>
            </label>

            <div class="po-reputation-player-impact-section">
              <div class="po-reputation-inline-head">
                <div>
                  <div class="po-section-title">Operations Projection</div>
                  <div class="po-op-summary">This is what the shared Operations reputation page exposes to players.</div>
                </div>
                <div class="po-reputation-log-meta">
                  <span class="po-reputation-log-chip">{{operationsVisibilityLabel}}</span>
                  <span class="po-reputation-log-chip">Standing {{score}} | {{access}}</span>
                </div>
              </div>
              <div class="po-reputation-detail-grid">
                <label class="po-switch">
                  <input type="checkbox" data-action="set-reputation-operations-visible" data-faction="{{id}}" {{#if visibleToOperations}}checked{{/if}} />
                  <span>Reveal this faction in Operations</span>
                </label>
              </div>
              <label class="po-resource-row po-notes-row-lg">
                <span>Operations Summary</span>
                <textarea class="po-input" rows="3" data-action="set-reputation-operations-field" data-faction="{{id}}" data-field="operationsSummary" placeholder="What the party openly knows about this faction.">{{operationsSummary}}</textarea>
              </label>
              <label class="po-resource-row po-notes-row-lg">
                <span>Operations Current Note</span>
                <textarea class="po-input" rows="3" data-action="set-reputation-operations-field" data-faction="{{id}}" data-field="operationsNote" placeholder="Current player-facing result or status update.">{{operationsNote}}</textarea>
              </label>
            </div>

            <div class="po-reputation-player-impact-section">
              <div class="po-reputation-inline-head">
                <div>
                  <div class="po-section-title">Player Influence</div>
                  <div class="po-op-summary">Current faction increases or decreases based on the players.</div>
                </div>
                <div class="po-reputation-log-meta">
                  <span class="po-reputation-log-chip po-reputation-impact-total {{playerImpactToneClass}}">Current Total {{playerImpactTotalLabel}}</span>
                  <span class="po-reputation-log-chip">{{playerImpactCount}} linked entries</span>
                </div>
              </div>
              {{#if playerImpacts.length}}
              <div class="po-reputation-player-impact-list">
                {{#each playerImpacts}}
                <div class="po-reputation-player-impact-row">
                  <label class="po-resource-row">
                    <span>Player</span>
                    <select class="po-select" data-action="set-reputation-player-impact" data-faction="{{../id}}" data-impact-id="{{id}}" data-field="actorId">
                      {{#each actorOptions}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label class="po-resource-row">
                    <span>Delta</span>
                    <input type="number" min="-5" max="5" step="1" class="po-input" data-action="set-reputation-player-impact" data-faction="{{../id}}" data-impact-id="{{id}}" data-field="delta" value="{{delta}}" />
                  </label>
                  <label class="po-resource-row po-notes-row-lg">
                    <span>Reason / Note</span>
                    <textarea class="po-input" rows="2" data-action="set-reputation-player-impact" data-faction="{{../id}}" data-impact-id="{{id}}" data-field="note" placeholder="Why this player is moving the faction up or down.">{{note}}</textarea>
                  </label>
                  <button type="button" class="po-btn po-btn-sm is-danger" data-action="remove-reputation-player-impact" data-faction="{{../id}}" data-impact-id="{{id}}">Remove</button>
                </div>
                {{/each}}
              </div>
              {{else}}
              <div class="po-op-summary">No player-linked faction shifts tracked yet.</div>
              {{/if}}
              <div class="po-op-action-row">
                <button type="button" class="po-btn po-btn-sm" data-action="add-reputation-player-impact" data-faction="{{id}}">Add Player Influence</button>
              </div>
            </div>

            <div class="po-op-action-row po-reputation-primary-actions">
              <button type="button" class="po-btn po-btn-sm" data-action="log-reputation-note" data-faction="{{id}}">Log Note w/ World Date</button>
              <button type="button" class="po-btn po-btn-sm" data-action="clear-reputation-note" data-faction="{{id}}">Clear Draft</button>
            </div>

            <div class="po-reputation-log-row">
              <label class="po-resource-row">
                <span>Review Logged Notes{{#if hasNoteLogs}} ({{noteLogCount}}){{/if}}</span>
                <select class="po-select" data-action="load-reputation-note-log" data-faction="{{id}}">
                  <option value="">Select a logged note...</option>
                  {{#each noteLogOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="po-sop-note-view po-reputation-log-view">
                <div class="po-reputation-log-meta">
                  {{#if hasSelectedNoteLog}}
                  <span class="po-reputation-log-chip">Logged {{selectedNoteLogDayLabel}}</span>
                  <span class="po-reputation-log-chip">Rep {{selectedNoteLogScoreLabel}}</span>
                  {{#if selectedNoteLogClockLabel}}<span class="po-reputation-log-chip">{{selectedNoteLogClockLabel}}</span>{{/if}}
                  <span class="po-reputation-log-chip">By {{selectedNoteLogLoggedBy}}</span>
                  {{#if hasSelectedNoteLogCalendar}}<span class="po-reputation-log-chip">Calendar Synced</span>{{/if}}
                  {{else}}
                  <span class="po-reputation-log-chip is-muted">Archived notes stay here for review</span>
                  {{/if}}
                </div>
                <div class="po-sop-note-view-body {{#unless hasSelectedNoteLog}}is-empty{{/unless}}">
                  {{#if hasSelectedNoteLog}}
                  {{selectedNoteLogText}}
                  {{else}}
                  {{#if hasNoteLogs}}
                  Select a logged note to read it here without overwriting the current draft.
                  {{else}}
                  No archived notes yet.
                  {{/if}}
                  {{/if}}
                </div>
              </div>
              <div class="po-op-action-row po-reputation-log-actions">
                <button type="button" class="po-btn po-btn-sm" data-action="use-reputation-note-log" data-faction="{{id}}" {{#unless hasSelectedNoteLog}}disabled{{/unless}}>Load Into Editor</button>
                <button type="button" class="po-btn po-btn-sm" data-action="post-reputation-note-log" data-faction="{{id}}" {{#unless hasSelectedNoteLog}}disabled{{/unless}}>Post Selected Note</button>
                {{#if hasSelectedNoteLogJournal}}
                <button type="button" class="po-btn po-btn-sm" data-action="open-journal-entry" data-journal-id="{{selectedNoteLogJournalEntryId}}">Open Archive</button>
                {{/if}}
                <button type="button" class="po-btn po-btn-sm is-danger" data-action="remove-reputation-note-log" data-faction="{{id}}" {{#unless hasSelectedNoteLog}}disabled{{/unless}}>Delete Logged Note</button>
              </div>
            </div>

            {{#unless isCore}}
            <button type="button" class="po-btn po-btn-sm is-danger po-reputation-remove-btn" data-action="remove-reputation-faction" data-faction="{{id}}">Remove Faction</button>
            {{/unless}}
            </div>
          </details>
          {{/each}}
        </div>
        {{else}}
        <div class="po-op-role-row">
          <div class="po-section-title">No factions matched the current filter.</div>
          <div class="po-op-summary">Clear the filters or create a new faction to begin tracking reputation here.</div>
        </div>
        {{/if}}
      </div>
    </section>
  </div>
</div>
