<div class="po-window po-window-rest" data-tool="gm-weather" role="region" aria-label="Party Operations GM Weather">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">GM Weather - Generated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-page-back">Back to Cockpit</button>
      <button type="button" class="po-icon-btn" data-action="gm-weather-page-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-gm-shell" id="po-panel-gm-weather-page">
      {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs" isWeather=true}}

      <section class="po-gm-section po-weather-hero po-gm-page-intro">
        <div class="po-weather-hero-copy po-gm-page-copy">
          <div class="po-gm-page-eyebrow">Simple Calendar Weather</div>
          <div class="po-pill">{{#if weatherTools.calendar.simpleCalendarActive}}Calendar Connected{{else}}Calendar Unavailable{{/if}}</div>
          <h2 class="po-section-title">Weather</h2>
          <div class="po-op-summary">{{weatherTools.calendar.dateLabel}} - {{weatherTools.calendar.climate}} {{weatherTools.calendar.season}}</div>
          <div class="po-op-action-row po-gm-page-actions">
            <button type="button" class="po-btn po-btn-sm is-primary" data-action="gm-weather-roll">Roll And Log Weather</button>
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-clear-terrain">Clear Terrain</button>
          </div>
        </div>
        <div class="po-weather-metric-grid po-gm-page-stat-grid" role="list" aria-label="Weather summary">
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Current</div>
            <div class="po-weather-metric-value">{{weather.currentLabel}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Visibility</div>
            <div class="po-weather-metric-value">{{weather.currentVisibilityModifier}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Darkness</div>
            <div class="po-weather-metric-value">{{weather.currentDarkness}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Last Roll</div>
            <div class="po-weather-metric-value">{{weatherTools.calendar.lastRolledAtLabel}}</div>
          </div>
        </div>
      </section>

      <div class="po-weather-main-grid">
        <section class="po-gm-section po-weather-card">
          <div class="po-collapsible-head">
            <div>
              <div class="po-section-title">Climate</div>
              <div class="po-hint">Choose the regional climate used by the GM screen weather generator.</div>
            </div>
            <div class="po-pill">{{weatherTools.calendar.climateModeLabel}}</div>
          </div>

          <div class="po-weather-field-grid is-compact">
            <label class="po-resource-row">
              <span>Climate</span>
              <select name="calendarWeatherClimate" class="po-select" data-action="gm-weather-set-climate">
                {{#each weatherTools.calendar.climateOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>

            <label class="po-resource-row">
              <span>Auto-Log Daily</span>
              <input type="checkbox" data-action="gm-weather-toggle-auto" {{#if weatherTools.calendar.autoApply}}checked{{/if}} />
            </label>

            <label class="po-resource-row">
              <span>Use Terrain Climate</span>
              <input type="checkbox" data-action="gm-weather-toggle-auto-climate" {{#if weatherTools.calendar.climateAutoApply}}checked{{/if}} />
            </label>
          </div>

          <div class="po-weather-summary-list">
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Suggested Climate</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.recommendedClimate}} - {{weatherTools.calendar.recommendedClimateConfidence}} - {{weatherTools.calendar.recommendedClimateReason}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Terrain Profile</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.terrainSummary}}</span>
            </div>
          </div>

          <div class="po-op-action-row">
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-apply-suggested-climate" {{#unless weatherTools.calendar.canApplyRecommendedClimate}}disabled{{/unless}}>Apply Suggested Climate</button>
          </div>
        </section>

        <section class="po-gm-section po-weather-card">
          <div class="po-collapsible-head">
            <div>
              <div class="po-section-title">Terrain</div>
              <div class="po-hint">Set the region profile that shapes temperature, rainfall, visibility, and travel impact.</div>
            </div>
          </div>

          <div class="po-weather-field-grid is-compact">
            {{#each weatherTools.calendar.terrainRows}}
            <label class="po-resource-row" title="{{hint}}">
              <span>{{label}}</span>
              <input type="number" min="0" max="20" step="1" class="po-input" data-action="gm-weather-set-terrain" data-terrain-key="{{key}}" value="{{value}}" />
            </label>
            {{/each}}
          </div>
        </section>
      </div>

      <details class="po-panel-disclosure po-gm-advanced-disclosure">
        <summary class="po-panel-disclosure-summary">
          <span class="po-section-title">Map PNG Terrain Import</span>
          <span class="po-op-summary">Optional helper for filling the terrain profile from a region map</span>
        </summary>
        <div class="po-panel-disclosure-body">
          <div class="po-weather-field-grid is-compact">
            <label class="po-resource-row">
              <span>Terrain PNG</span>
              <input type="text" class="po-input" data-action="gm-weather-set-terrain-image" value="{{weatherTools.calendar.terrainImagePath}}" placeholder="worlds/your-world/maps/county.png" />
            </label>

            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">PNG Import</span>
              <span class="po-weather-summary-copy">
                {{#if weatherTools.calendar.terrainImportedSummary}}
                {{weatherTools.calendar.terrainImportedSummary}} - {{weatherTools.calendar.terrainImportedAtLabel}}
                {{else}}
                {{#if weatherTools.calendar.hasTerrainImagePath}}
                {{weatherTools.calendar.terrainImagePath}} - not imported
                {{else}}
                Choose a county/map PNG, then import terrain.
                {{/if}}
                {{/if}}
              </span>
            </div>
          </div>

          <div class="po-op-action-row">
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-browse-terrain-image">Browse PNG</button>
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-preview-terrain-image" {{#unless weatherTools.calendar.hasTerrainImagePath}}disabled{{/unless}}>Preview PNG Terrain</button>
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-import-terrain-image" {{#unless weatherTools.calendar.hasTerrainImagePath}}disabled{{/unless}}>Import PNG Terrain</button>
            {{#if weatherTools.calendar.hasTerrainJournalEntry}}
            <button type="button" class="po-btn po-btn-sm" data-action="open-journal-entry" data-journal-id="{{weatherTools.calendar.terrainJournalEntryId}}">Open Terrain Archive</button>
            {{/if}}
          </div>

          {{#if weatherTools.calendar.hasTerrainImageAnalysis}}
          <div class="po-weather-summary-list">
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">PNG Analysis</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.terrainAnalysisModeLabel}} - {{weatherTools.calendar.terrainAnalysisSummary}} - confidence {{weatherTools.calendar.terrainImageAnalysis.confidenceLabel}} - ignored {{weatherTools.calendar.terrainImageAnalysis.ignoredPercentLabel}}</span>
            </div>
            {{#each weatherTools.calendar.terrainAnalysisRows}}
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">{{label}}</span>
              <span class="po-weather-summary-copy">Weight {{value}} - {{pixelCount}} px - {{percentLabel}}</span>
            </div>
            {{/each}}
          </div>
          {{/if}}
        </div>
      </details>

      <section class="po-gm-section po-weather-card">
        <div class="po-collapsible-head">
          <div>
            <div class="po-section-title">History</div>
            <div class="po-hint">Recent weather logs are archived in the Operations Journal.</div>
          </div>
        </div>
        {{#if weather.hasLogs}}
        <div class="po-weather-log-list">
          {{#each weather.logs}}
          <article class="po-weather-log-row">
            <div class="po-weather-log-head">
              <div>
                <div class="po-weather-log-title">{{label}}</div>
                <div class="po-weather-log-meta">Visibility {{visibilityModifier}} - Darkness {{darkness}}</div>
              </div>
              <div class="po-op-action-row">
                {{#if hasJournalEntry}}
                <button type="button" class="po-btn po-btn-sm" data-action="open-journal-entry" data-journal-id="{{journalEntryId}}">Open Archive</button>
                {{/if}}
                <button type="button" class="po-btn po-btn-sm is-danger" data-action="gm-weather-remove-log" data-log-id="{{id}}">Remove</button>
              </div>
            </div>
            <div class="po-op-summary">{{loggedAtLabel}} by {{loggedBy}}</div>
            {{#if hasDetailsText}}
            <div class="po-op-summary">{{detailsText}}</div>
            {{/if}}
            {{#if note}}
            <div class="po-op-summary">Note: {{note}}</div>
            {{/if}}
          </article>
          {{/each}}
        </div>
        {{else}}
        <div class="po-op-summary">No weather logs yet.</div>
        {{/if}}
      </section>
    </section>
  </div>
</div>
