<div class="po-window po-window-rest" data-tool="gm-weather" role="region" aria-label="Party Operations GM Weather">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">GM Weather - Generated {{generatedAtLabel}} by {{generatedBy}}</div>
    </div>
    <div class="po-controls">
      <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-page-back">Back to Cockpit</button>
      <button type="button" class="po-icon-btn" data-action="gm-weather-page-refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
    </div>
  </header>

  <div class="po-body">
    <section class="po-content po-gm-shell" id="po-panel-gm-weather-page">
      {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs" isWeather=true}}

      <section class="po-gm-section po-weather-hero po-gm-page-intro">
        <div class="po-weather-hero-copy po-gm-page-copy">
          <div class="po-gm-page-eyebrow">Simple Calendar Weather</div>
          <div class="po-pill">{{#if weatherTools.calendar.simpleCalendarActive}}Calendar Connected{{else}}Calendar Unavailable{{/if}}</div>
          <h2 class="po-section-title">Weather</h2>
          <div class="po-op-summary">{{weatherTools.calendar.dateLabel}} - {{weatherTools.calendar.locationLabel}} - {{weatherTools.calendar.climate}} {{weatherTools.calendar.season}}</div>
          <div class="po-op-action-row po-gm-page-actions">
            <button type="button" class="po-btn po-btn-sm is-primary" data-action="gm-weather-roll">Roll And Log Weather</button>
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-plot-week" {{#unless weatherTools.calendar.canPlotForecastWeek}}disabled{{/unless}}>Save 7 Days To Calendar</button>
          </div>
        </div>
        <div class="po-weather-metric-grid po-gm-page-stat-grid" role="list" aria-label="Weather summary">
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Current</div>
            <div class="po-weather-metric-value">{{weather.currentLabel}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Moon</div>
            <div class="po-weather-metric-value">{{weatherTools.calendar.lunarSummary}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Visibility</div>
            <div class="po-weather-metric-value">{{weather.currentVisibilityModifier}}</div>
          </div>
          <div class="po-weather-metric po-gm-page-stat" role="listitem">
            <div class="po-weather-metric-label">Last Roll</div>
            <div class="po-weather-metric-value">{{weatherTools.calendar.lastRolledAtLabel}}</div>
          </div>
        </div>
      </section>

      <div class="po-weather-main-grid">
        <section class="po-gm-section po-weather-card">
          <div class="po-collapsible-head">
            <div>
              <div class="po-section-title">Current Location</div>
              <div class="po-hint">Select where the players are right now; climate and terrain are derived from that location.</div>
            </div>
            <div class="po-pill">{{weatherTools.calendar.climate}} {{weatherTools.calendar.season}}</div>
          </div>

          <div class="po-weather-field-grid is-compact">
            <label class="po-resource-row">
              <span>Location</span>
              <select name="calendarWeatherLocation" class="po-select" data-action="gm-weather-set-location">
                {{#each weatherTools.calendar.locationOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>

            <label class="po-resource-row">
              <span>Auto-Log Daily</span>
              <input type="checkbox" data-action="gm-weather-toggle-auto" {{#if weatherTools.calendar.autoApply}}checked{{/if}} />
            </label>
          </div>

          <div class="po-weather-summary-list">
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Pattern</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.locationDescription}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Terrain Effect</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.terrainSummary}}</span>
            </div>
          </div>
        </section>

        <section class="po-gm-section po-weather-card">
          <div class="po-collapsible-head">
            <div>
              <div class="po-section-title">Moon And Season</div>
              <div class="po-hint">Simple Calendar date, season, and lunar phase shape the generated weather.</div>
            </div>
            <div class="po-pill">{{weatherTools.calendar.lunarSource}}</div>
          </div>

          <div class="po-weather-summary-list">
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Season</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.season}} - {{weatherTools.calendar.dateLabel}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Moon</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.lunarPlainSummary}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Moon Meaning</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.lunarPhaseMeaning}} {{weatherTools.calendar.lunarIlluminationMeaning}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">Tides</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.lunarTideSummary}}</span>
            </div>
            <div class="po-weather-summary-item">
              <span class="po-weather-summary-label">At Table</span>
              <span class="po-weather-summary-copy">{{weatherTools.calendar.lunarSignificance}}</span>
            </div>
          </div>
        </section>
      </div>

      <section class="po-gm-section po-weather-card">
        <div class="po-collapsible-head">
          <div>
            <div class="po-section-title">Forecast</div>
            <div class="po-hint">Preview the location pattern against upcoming Simple Calendar days. Last saved week: {{weatherTools.calendar.lastForecastPlottedAtLabel}}.</div>
          </div>
          <div class="po-op-action-row">
            <button type="button" class="po-btn po-btn-sm" data-action="gm-weather-plot-week" {{#unless weatherTools.calendar.canPlotForecastWeek}}disabled{{/unless}}>Save Week</button>
            <label class="po-resource-row">
              <span>Range</span>
              <select name="calendarWeatherForecastDays" class="po-select" data-action="gm-weather-set-forecast-days">
                {{#each weatherTools.calendar.forecastDayOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
          </div>
        </div>
        {{#if weatherTools.calendar.hasForecastRows}}
        <div class="po-weather-log-list">
          {{#each weatherTools.calendar.forecastRows}}
          <article class="po-weather-log-row">
            <div class="po-weather-log-head">
              <div>
                <div class="po-weather-log-title">{{offsetLabel}} - {{weatherLabel}}</div>
                <div class="po-weather-log-meta">{{dateLabel}} - {{season}} - {{tempLabel}} - Precip {{rainLabel}}</div>
              </div>
              <span class="po-pill">{{lunarSignificanceLabel}}</span>
            </div>
            <div class="po-op-summary">System: {{weatherSystemSummary}}</div>
            <div class="po-op-summary">{{precipitationExplanation}}</div>
            <div class="po-op-summary">Moon: {{lunarPlainSummary}} {{lunarTideSummary}}</div>
            <div class="po-op-summary">Hazards: {{hazardLabel}}</div>
          </article>
          {{/each}}
        </div>
        {{else}}
        <div class="po-op-summary">No forecast rows available.</div>
        {{/if}}
      </section>

      <section class="po-gm-section po-weather-card">
        <div class="po-collapsible-head">
          <div>
            <div class="po-section-title">History</div>
            <div class="po-hint">Recent weather logs are archived in the Operations Journal.</div>
          </div>
        </div>
        {{#if weather.hasLogs}}
        <div class="po-weather-log-list">
          {{#each weather.logs}}
          <article class="po-weather-log-row">
            <div class="po-weather-log-head">
              <div>
                <div class="po-weather-log-title">{{label}}</div>
                <div class="po-weather-log-meta">Visibility {{visibilityModifier}} - Darkness {{darkness}}</div>
              </div>
              <div class="po-op-action-row">
                {{#if hasJournalEntry}}
                <button type="button" class="po-btn po-btn-sm" data-action="open-journal-entry" data-journal-id="{{journalEntryId}}">Open Archive</button>
                {{/if}}
                <button type="button" class="po-btn po-btn-sm is-danger" data-action="gm-weather-remove-log" data-log-id="{{id}}">Remove</button>
              </div>
            </div>
            <div class="po-op-summary">{{loggedAtLabel}} by {{loggedBy}}</div>
            {{#if hasDetailsText}}
            <div class="po-op-summary">{{detailsText}}</div>
            {{/if}}
            {{#if note}}
            <div class="po-op-summary">Note: {{note}}</div>
            {{/if}}
          </article>
          {{/each}}
        </div>
        {{else}}
        <div class="po-op-summary">No weather logs yet.</div>
        {{/if}}
      </section>
    </section>
  </div>
</div>
