                    </td>
                    {{/if}}
                  </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
            {{else}}
            <div class="po-op-summary po-gather-history-empty">{{operations.resources.gatherHistory.emptyMessage}}</div>
