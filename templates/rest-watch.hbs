                <span>Healer's Kit Item</span>
                <select class="po-select" data-action="set-injury-config" data-injury-config="healersKitItemId" {{#unless injuryRecovery.supplies.kitSelection.hasActor}}disabled{{/unless}}>
                  {{#each injuryRecovery.supplies.kitSelection.itemOptions}}
                  <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                  {{/each}}
                </select>
