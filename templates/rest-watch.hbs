              </label>
            </div>

            <div class="po-injury-editor po-op-role-row">
            <div class="po-op-role-head">
              <div class="po-op-role-name">Track Injury</div>
              <div class="po-op-role-status">d100 table entry</div>
            </div>
            <select name="actorId" class="po-select">
              <option value="">Select actor</option>
              {{#each injuryRecovery.actorOptions}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
            <label class="po-resource-row">
              <span>Injury Result</span>
              <select name="injuryKey" class="po-select" data-action="set-injury-result">
                {{#each injuryRecovery.injuryOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label class="po-resource-row">
              <span>d100 Roll</span>
              <input name="injuryRoll" type="number" min="1" max="100" step="1" class="po-input" value="" placeholder="optional" />
            </label>
            <label class="po-resource-row">
              <span>Recovery Days (Formula)</span>
              <input name="recoveryDays" type="number" min="0" step="1" class="po-input" value="{{injuryRecovery.config.baseRecoveryDays}}" readonly />
            </label>
            <div class="po-hint" data-injury-recovery-formula>Recovery Formula: {{injuryRecovery.defaultRecoveryFormula}}</div>
            <label class="po-switch">
              <input name="stabilized" type="checkbox" />
              <span>Already Stabilized</span>
            </label>
            <label class="po-resource-row">
              <span>Notes</span>
              <input name="notes" type="text" class="po-input" placeholder="e.g., rib fracture, leg wound" />
