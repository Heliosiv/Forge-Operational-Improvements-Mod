            {{#each injuryRecovery.entries}}
            <div class="po-op-role-row" data-actor-id="{{actorId}}">
              <div class="po-op-role-head">
                <div class="po-op-role-name">{{actorName}}</div>
                <div class="po-op-role-status {{#if stabilized}}is-ready{{else}}is-missing{{/if}}">{{#if stabilized}}Stabilized{{else}}Unstable{{/if}}</div>
              </div>
              <div class="po-op-summary">Injury: {{injuryName}}{{#if injuryRoll}} (d100 {{injuryRoll}}){{/if}}</div>
              <div class="po-op-summary">Effect: {{effect}}</div>
              <div class="po-op-summary">Recovery: {{#if permanent}}Permanent{{else}}{{recoveryDays}} day(s){{/if}}</div>
              <div class="po-op-summary">Actor Effect: {{effectSummary}}</div>
              <div class="po-op-summary">Treatment: {{#if treatmentDc}}DC {{treatmentDc}} {{treatmentSkillLabel}}{{else}}None{{/if}} - Kit {{kitCharges}}</div>
              <div class="po-op-action-row">
                <button type="button" class="po-btn po-btn-sm" data-action="stabilize-injury" data-actor-id="{{actorId}}"><i class="fa-solid fa-kit-medical"></i> Stabilize</button>
                <button type="button" class="po-btn po-btn-sm" data-action="clear-injury" data-actor-id="{{actorId}}"><i class="fa-solid fa-xmark"></i> Remove</button>
              </div>
            </div>
            {{/each}}
          </div>

          <div class="po-op-summary">Active injuries: {{injuryRecovery.summary.activeInjuries}}</div>
          <div class="po-op-summary">Unstable injuries: {{injuryRecovery.summary.unstableCount}}</div>
          <div class="po-op-summary">Permanent injuries: {{injuryRecovery.summary.permanentCount}}</div>
          <div class="po-op-summary">Last cycle: {{injuryRecovery.summary.lastCycleAt}} ({{injuryRecovery.summary.lastCycleSummary}})</div>
          <button type="button" class="po-btn" data-action="apply-recovery-cycle"><i class="fa-solid fa-arrow-rotate-right"></i> Apply Recovery Cycle</button>
          <button type="button" class="po-btn po-btn-sm" data-action="show-recovery-brief"><i class="fa-solid fa-file-lines"></i> Show Recovery Brief</button>
        </div>

        {{/if}}

        {{/if}}

        {{#if @root.showGmPageTab}}
        {{#if operationsPageGm}}
        <section id="po-gm-workspace" class="po-content po-gm-shell po-gm-workspace-shell">
          {{> "modules/party-operations/templates/partials/gm-panel-nav.hbs"}}

          <div class="po-gm-workspace-grid po-gm-workspace-grid-compact">
            <section class="po-gm-section po-gm-workspace-card po-gm-resource-workspace po-gm-resource-workspace-compact">
              <div class="po-collapsible-head">
                <div>
                  <div class="po-section-title">Resources</div>
                  <div class="po-hint">Call players to choose PC-owned gatherers, then resolve incoming request cards.</div>
                </div>
                <div class="po-pill">{{operations.resources.gatherRequests.count}} pending</div>
              </div>
              <div class="po-gm-workspace-meta">
                <span class="po-pill">Food {{operations.resources.summary.pendingGatherFood}}</span>
                <span class="po-pill">Water {{operations.resources.summary.pendingGatherWater}}</span>
              </div>
              <div class="po-op-action-row">
                {{#if @root.isGM}}
                <button type="button" class="po-btn po-btn-sm po-gather-launch-btn" data-action="gather-resource-check" title="Call players to choose a PC-owned character for gathering">
                  <i class="fa-solid fa-seedling" aria-hidden="true"></i>
                  <span class="po-gather-launch-btn-copy">
                    <span class="po-gather-launch-btn-main">Call Gather</span>
                    <span class="po-gather-launch-btn-sub">Player Requests</span>
                  </span>
                </button>
                {{/if}}
              </div>
              <div class="po-op-divider"></div>
              <div class="po-gather-history-panel po-gather-queue-panel">
                <div class="po-section-head-row po-gather-history-head">
                  <div class="po-section-title">Pending Requests</div>
                  <div class="po-gather-history-head-tools">
                    <div class="po-op-summary">{{operations.resources.gatherRequests.count}} pending</div>
                  </div>
                </div>
                <div class="po-hint">Resolve request cards first. Prompt roll for standard cases, review details only when needed.</div>
                {{#if operations.resources.gatherRequests.hasRows}}
                <div class="po-gather-request-list">
                  {{#each operations.resources.gatherRequests.rows}}
                  <article class="po-gather-request-card {{#if isSafeDefault}}is-safe{{else}}is-risk{{/if}}">
                    <div class="po-gather-request-head">
                      <div class="po-gather-request-title-wrap">
                        <div class="po-op-role-name">{{actorName}}</div>
                        <div class="po-op-summary">Requester {{requesterName}} | {{requestedAtLabel}}</div>
                      </div>
                      <div class="po-gather-request-tier">{{riskLevelLabel}}</div>
                    </div>

                    <div class="po-gather-chip-row">
                      <span class="po-gather-chip">{{resourceTypeLabel}}</span>
                      <span class="po-gather-chip">{{gatherModeLabel}}</span>
                      <span class="po-gather-chip">{{travelModeLabel}}</span>
                      <span class="po-gather-chip">{{environmentLabel}}</span>
                      <span class="po-gather-chip">{{travelTradeoffLabel}}</span>
                    </div>

                    <div class="po-gather-mod-summary">{{modifierSummary}}</div>

                    {{#if hasRiskTags}}
                    <div class="po-gather-chip-row">
                      {{#each riskTags}}
                      <span class="po-gather-chip is-{{tone}}">{{label}}</span>
                      {{/each}}
                    </div>
                    {{/if}}

                    {{#if hasMatchingPreset}}
                    <div class="po-op-summary">Preset match: {{matchingPresetLabel}}</div>
                    {{/if}}

                    {{#if @root.operations.resources.gatherRequests.isManager}}
                    <div class="po-op-action-row">
                      <button type="button" class="po-btn po-btn-sm" data-action="approve-gather-request" data-request-id="{{id}}">{{primaryActionLabel}}</button>
                      <button type="button" class="po-btn po-btn-sm is-danger" data-action="decline-gather-request" data-request-id="{{id}}">{{declineActionLabel}}</button>
                    </div>
                    {{/if}}
                  </article>
                  {{/each}}
                </div>
                {{else}}
                <div class="po-op-summary po-gather-history-empty">{{operations.resources.gatherRequests.emptyMessage}}</div>
                {{/if}}
              </div>

              <div class="po-op-divider"></div>
              <details class="po-panel-disclosure po-gather-history-disclosure">
                <summary class="po-panel-disclosure-summary">
                  <span class="po-section-title">Gather History</span>
                  <span class="po-op-summary">Showing {{operations.resources.gatherHistory.visibleCount}} of {{operations.resources.gatherHistory.totalCount}}</span>
                </summary>
                <div class="po-panel-disclosure-body">
                  <div class="po-gather-history-head-tools">
                    <div class="po-gather-history-head-actions">
                      <button type="button" class="po-btn po-btn-sm" data-action="clear-gather-history-filters">Reset Filters</button>
                      <button type="button" class="po-btn po-btn-sm" data-action="clear-gather-history">Clear History</button>
                    </div>
                  </div>
                  <div class="po-gather-history-controls">
                    <label class="po-resource-row is-search">
                      <span>Search</span>
                      <input
                        type="text"
                        class="po-input"
                        data-action="set-gather-history-filter"
                        data-filter-key="search"
                        value="{{operations.resources.gatherHistory.filters.search}}"
                        placeholder="{{operations.resources.gatherHistory.filters.searchPlaceholder}}" />
                    </label>
                    <label class="po-resource-row">
                      <span>Result</span>
                      <select class="po-select" data-action="set-gather-history-filter" data-filter-key="result">
                        {{#each operations.resources.gatherHistory.resultOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                    </label>
                    <label class="po-resource-row">
                      <span>Type</span>
                      <select class="po-select" data-action="set-gather-history-filter" data-filter-key="resource">
                        {{#each operations.resources.gatherHistory.resourceOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                    </label>
                    <label class="po-resource-row">
                      <span>Environment</span>
                      <select class="po-select" data-action="set-gather-history-filter" data-filter-key="environment">
                        {{#each operations.resources.gatherHistory.environmentOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                    </label>
                    <label class="po-resource-row">
                      <span>Actor</span>
                      <select class="po-select" data-action="set-gather-history-filter" data-filter-key="actor">
                        {{#each operations.resources.gatherHistory.actorOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                    </label>
                    <label class="po-resource-row is-sort">
                      <span>Sort</span>
                      <select class="po-select" data-action="set-gather-history-filter" data-filter-key="sort">
                        {{#each operations.resources.gatherHistory.sortOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                    </label>
                  </div>
                  {{#if operations.resources.gatherHistory.hasRows}}
                  <div class="po-gather-history-wrap">
                    <table class="po-gather-history-table">
                      <thead>
                        <tr>
                          <th>When</th>
                          <th>Actor</th>
                          <th>Environment</th>
                          <th>Result</th>
                          <th>Roll</th>
                          <th>Type</th>
                          <th>Rations</th>
                          <th>Notes</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each operations.resources.gatherHistory.rows}}
                        <tr>
                          <td>{{timestampLabel}}</td>
                          <td>{{actorName}}</td>
                          <td>{{environmentLabel}}</td>
                          <td><span class="po-gather-history-result {{resultClass}}">{{resultLabel}}</span></td>
                          <td>{{rollVsDc}}</td>
                          <td>{{resourceTypeLabel}}</td>
                          <td>{{rations}}</td>
                          <td class="po-gather-history-notes">{{detailsText}}</td>
                          <td class="po-gather-history-actions">
                            <button type="button" class="po-btn po-btn-sm is-danger" data-action="remove-gather-history-entry" data-history-id="{{id}}">Delete</button>
                          </td>
                        </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                  {{else}}
                  <div class="po-op-summary po-gather-history-empty">{{operations.resources.gatherHistory.emptyMessage}}</div>
                  {{/if}}
                </div>
              </details>
            </section>
          </div>
        </section>

        
        {{/if}}
        {{/if}}
      </aside>
      {{/if}}
      {{/if}}
    </div>
  </section>
  </div>
  </div>

  <footer class="po-footer">
    <div class="po-footer-text">Party Operations</div>
    <div class="po-footer-text">State synchronized per party</div>
  </footer>
</div>



