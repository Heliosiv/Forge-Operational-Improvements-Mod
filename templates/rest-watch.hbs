              <button type="button" class="po-btn po-btn-sm" data-action="roll-injury-table"><i class="fa-solid fa-dice-d20"></i> Roll d100</button>
              <button type="button" class="po-btn po-btn-sm" data-action="show-injury-table"><i class="fa-solid fa-table-list"></i> View Table</button>
            </div>
            <button type="button" class="po-btn" data-action="upsert-injury"><i class="fa-solid fa-heart-pulse"></i> Save Injury</button>
            </div>
          </div>

          <div class="po-op-divider"></div>

