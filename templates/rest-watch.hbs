              <div class="po-op-summary" title="{{injuryRecovery.supplies.kitSelection.chargeSourcesTooltip}}">Total Healer's Kit Charges Available: {{injuryRecovery.supplies.kitSelection.totalCharges}}</div>
              <label class="po-resource-row">
                <span>Base Recovery Days</span>
