<div class="po-window po-window-rest" data-tool="{{windowToolId}}" data-main-tab="{{mainTab}}" role="region" aria-label="{{windowAriaLabel}}">
  <header class="po-header">
    <div class="po-header-main">
      <h1 class="po-title">Party Operations <span class="po-pill">v{{moduleVersion}}</span></h1>
      <div class="po-subtitle" aria-live="polite">{{mainSubtitleLabel}} - Last updated {{lastUpdatedAt}} by {{lastUpdatedBy}}</div>
    </div>
    <nav class="po-tabs po-tabs-main po-tabs-main-header" role="tablist" aria-label="Party Operations views">
      <button type="button" role="tab" tabindex="{{#if mainTabRestWatch}}0{{else}}-1{{/if}}" class="po-tab {{#if mainTabRestWatch}}is-active{{/if}}" data-action="switch-tab" data-tab="rest" aria-selected="{{#if mainTabRestWatch}}true{{else}}false{{/if}}" aria-current="{{#if mainTabRestWatch}}page{{else}}false{{/if}}">Rest Watch</button>
      <button type="button" role="tab" tabindex="-1" class="po-tab" data-action="switch-tab" data-tab="march" aria-selected="false" aria-current="false">Marching Order</button>
      <button type="button" role="tab" tabindex="{{#if mainTabOperations}}0{{else}}-1{{/if}}" class="po-tab {{#if mainTabOperations}}is-active{{/if}}" data-action="switch-tab" data-tab="operations" aria-selected="{{#if mainTabOperations}}true{{else}}false{{/if}}" aria-current="{{#if mainTabOperations}}page{{else}}false{{/if}}">Operations</button>
      {{#if showGmPageTab}}
      <button type="button" role="tab" tabindex="{{#if mainTabGm}}0{{else}}-1{{/if}}" class="po-tab {{#if mainTabGm}}is-active{{/if}}" data-action="switch-tab" data-tab="gm" aria-selected="{{#if mainTabGm}}true{{else}}false{{/if}}" aria-current="{{#if mainTabGm}}page{{else}}false{{/if}}">GM</button>
      {{/if}}
    </nav>
    <div class="po-controls">
      {{#if showGmPageTab}}
      <button type="button" class="po-icon-btn" data-action="open-settings-hub" aria-label="Open Settings Hub" title="Open Settings Hub">
        <i class="fa-solid fa-gear"></i>
      </button>
      {{/if}}
      <button type="button" class="po-icon-btn" data-action="refresh" aria-label="Refresh">
        <i class="fa-solid fa-rotate"></i>
      </button>
      {{#if showPopout}}
      <button type="button" class="po-icon-btn" data-action="popout" aria-label="Pop out">
        <i class="fa-solid fa-up-right-from-square"></i>
      </button>
      {{/if}}
    </div>
  </header>

  <div class="po-body">
  <div class="po-primary-shell">

  {{#if mainTabRestWatch}}
  <section class="po-overview" aria-label="Rest watch status">
    <article class="po-overview-card">
      <span>Slots Filled</span>
      <strong>{{overview.occupiedSlots}} / {{overview.totalSlots}}</strong>
    </article>
    <article class="po-overview-card">
      <span>Assigned Entries</span>
      <strong>{{overview.assignedEntries}}</strong>
    </article>
    <article class="po-overview-card {{#if overview.hasLowDarkvisionCoverage}}is-alert{{/if}}">
      <span>Low Darkvision Slots</span>
      <strong>{{overview.lowDarkvisionSlots}}</strong>
    </article>
    <article class="po-overview-card">
      <span>Campfire</span>
      <strong>{{overview.campfireState}}</strong>
    </article>
  </section>
  {{#if isGM}}
  <div class="po-overview-actions">
    <div class="po-rest-watch-toolbar">
      <button type="button" class="po-btn po-btn-sm po-rest-campfire-all {{#if campfireOverview.allLit}}is-active{{/if}}" data-action="toggle-campfire-all">
        <i class="fa-solid fa-fire"></i> {{campfireOverview.toggleAllLabel}}
      </button>
      <details class="po-rest-settings-menu">
        <summary class="po-rest-settings-summary" aria-label="Watch settings" title="Watch settings">
          <i class="fa-solid fa-gear"></i>
        </summary>
        <div class="po-rest-settings-menu-panel">
          <div class="po-rest-settings-body">
            <div class="po-rest-settings-group">
              <div class="po-section-title">Auto-Fill</div>
              <div class="po-op-summary {{#if autofillSummary.hasOverflow}}is-warn{{/if}}">
                Roster {{autofillSummary.rosterCount}} | Visible Slots {{autofillSummary.visibleCapacity}}{{#if autofillSummary.hasOverflow}} | Overflow {{autofillSummary.overflowCount}}{{/if}}
              </div>
              {{#if autofillSummary.hasOverflow}}
              <div class="po-op-summary is-warn">Add slots or assign manually for remaining actors.</div>
              {{/if}}
              <button type="button" class="po-btn" data-action="autofill-party"><i class="fa-solid fa-users"></i> Fill from Active Party</button>
              <button type="button" class="po-btn" data-action="autofill-last"><i class="fa-solid fa-clock-rotate-left"></i> Fill from Last Session</button>
            </div>
            <div class="po-rest-settings-group">
              <div class="po-section-title">Snapshot</div>
              <button type="button" class="po-btn" data-action="commit-plan"><i class="fa-solid fa-floppy-disk"></i> Save Snapshot</button>
            </div>
            <div class="po-rest-settings-group">
              <div class="po-section-title">Visibility</div>
              <select class="po-select" data-action="visibility">
                {{#each visibilityOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
            <div class="po-rest-settings-group po-rest-settings-group-danger">
              <div class="po-section-title">Plan</div>
              <button type="button" class="po-btn is-danger" data-action="clear-all"><i class="fa-solid fa-trash"></i> Clear Plan</button>
            </div>
          </div>
        </div>
      </details>
    </div>
  </div>
  {{/if}}

  {{/if}}

  <section class="po-content" id="{{#if mainTabRestWatch}}po-panel-rest-watch{{else}}po-panel-operations{{/if}}">
    <div class="po-grid po-primary-layout {{#if mainTabRestWatch}}is-rest-watch-layout{{/if}} {{#if mainTabOperationsOrGm}}is-operations-layout{{/if}}">
      {{#if mainTabRestWatch}}
      <div class="po-cards">
        {{#each slots}}
        <article class="po-card po-watch-card" data-slot-id="{{id}}">
          <div class="po-watch-card-shell">
            <section class="po-watch-assign-pane">
              <div class="po-watch-card-head">
                <div>
                  <div class="po-slot-badge">{{label}}</div>
                  <div class="po-op-summary">Assignments {{assignedCount}} / {{maxEntries}}</div>
                </div>
              </div>

              {{#if @root.isGM}}
              <div class="po-watch-assignment-list">
                {{#each assignmentRows}}
                <div
                  class="po-watch-assignment-row {{#if occupied}}is-filled{{/if}} {{#unless isVisible}}is-hidden{{/unless}}"
                  data-entry-index="{{index}}">
                  <label class="po-watch-assignment-label" for="po-slot-select-{{../id}}-{{index}}">{{slotLabel}}</label>
                  <div class="po-watch-assignment-controls">
                    <select
                      id="po-slot-select-{{../id}}-{{index}}"
                      class="po-select po-watch-slot-select"
                      data-action="set-slot-entry"
                      data-slot-id="{{../id}}"
                      data-entry-index="{{index}}"
                      data-committed-actor-id="{{committedActorId}}">
                      {{#each selectOptions}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <button
                      type="button"
                      class="po-icon-btn"
                      data-action="clear-slot-entry"
                      data-slot-id="{{../id}}"
                      data-entry-index="{{index}}"
                      data-committed-actor-id="{{committedActorId}}"
                      aria-label="{{clearButtonLabel}}"
                      title="{{clearButtonLabel}}"
                      {{#unless hasSelectableValue}}{{#unless canRemoveVisibleSlot}}disabled{{/unless}}{{/unless}}>
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </div>
                  <span class="po-slot-chip po-watch-mini-stat {{#unless hasActorDetails}}is-muted{{/unless}}">PP {{#if hasPassivePerception}}{{actor.passivePerception}}{{else}}-{{/if}}</span>
                  <span class="po-slot-chip po-watch-mini-stat {{#unless hasActorDetails}}is-muted{{/unless}}">PI {{#if hasPassiveInvestigation}}{{actor.passiveInvestigation}}{{else}}-{{/if}}</span>
                </div>
                {{/each}}
              </div>
              <div class="po-assign-actions po-watch-assignment-actions">
                <button type="button" class="po-btn" data-action="assign-actor-global" data-slot-id="{{id}}" {{#unless canAddVisibleSlot}}disabled{{/unless}}>
                  <i class="fa-solid fa-plus"></i> Add Slot
                </button>
              </div>
              {{else}}
              <div class="po-watch-assignment-readonly">
                {{#if hasEntries}}
                {{#each entries}}
                <div class="po-watch-readonly-row {{#if isActiveCharacter}}is-active{{/if}}">
                  <img class="po-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
                  <div class="po-watch-readonly-copy">
                    <strong>{{actor.name}}</strong>
                    <span>{{activity.activityLabel}}</span>
                  </div>
                </div>
                {{/each}}
                {{else}}
                <div class="po-empty"><div class="po-empty-text">No one assigned yet.</div></div>
                {{/if}}
                {{#if canAssignMe}}
                <div class="po-assign-actions">
                  <button type="button" class="po-btn is-primary" data-action="assign-me">Assign Me</button>
                </div>
                {{/if}}
              </div>
              {{/if}}
            </section>

            <section class="po-watch-detail-pane">
              <div class="po-watch-detail-head">
                <div>
                  <div class="po-section-title">Watch Summary</div>
                  <div class="po-op-summary">{{label}} totals for GM reference.</div>
                </div>
                {{#if @root.isGM}}
                <button
                  type="button"
                  class="po-campfire-toggle {{#if campfireActive}}is-active{{else}}is-inactive{{/if}}"
                  data-action="toggle-campfire"
                  data-slot-id="{{id}}"
                  data-slot-label="{{label}}"
                  aria-pressed="{{#if campfireActive}}true{{else}}false{{/if}}">
                  <i class="fa-solid fa-fire"></i>
                  <span>{{campfireState}}</span>
                </button>
                {{else}}
                <div class="po-campfire-status {{#if campfireActive}}is-active{{else}}is-inactive{{/if}}">
                  <i class="fa-solid fa-fire"></i>
                  <span>{{campfireState}}</span>
                </div>
                {{/if}}
              </div>

              <div class="po-slot-insights po-watch-detail-chips">
                <div class="po-slot-chip">{{detailSummary.activeCountLabel}}</div>
                <div class="po-slot-chip">{{detailSummary.openCountLabel}}</div>
                <div class="po-slot-chip">{{detailSummary.languagesCountLabel}}</div>
                <div class="po-slot-chip {{#if detailSummary.hasCoverageWarning}}is-warn{{/if}}">{{detailSummary.coverageLabel}}</div>
              </div>

              <div class="po-watch-total-grid">
                <article class="po-watch-total-card">
                  <div class="po-watch-total-label">Passive Perception</div>
                  <div class="po-watch-total-value">{{detailSummary.ppRangeLabel}}</div>
                </article>
                <article class="po-watch-total-card">
                  <div class="po-watch-total-label">Passive Investigation</div>
                  <div class="po-watch-total-value">{{detailSummary.pivRangeLabel}}</div>
                </article>
                <article class="po-watch-total-card {{detailSummary.coverageStateClass}}">
                  <div class="po-watch-total-label">Coverage</div>
                  <div class="po-watch-total-value">{{detailSummary.coverageLabel}}</div>
                </article>
                <article class="po-watch-total-card {{detailSummary.campfireStateClass}}">
                  <div class="po-watch-total-label">Campfire</div>
                  <div class="po-watch-total-value">{{detailSummary.campfireLabel}}</div>
                </article>
                <article class="po-watch-total-card po-watch-total-card-wide">
                  <div class="po-watch-total-label">Known Languages</div>
                  <div class="po-watch-total-value {{#unless detailSummary.hasLanguages}}is-muted{{/unless}}" {{#if detailSummary.languagesTooltip}}title="{{detailSummary.languagesTooltip}}"{{/if}}>{{detailSummary.languagesLabel}}</div>
                </article>
              </div>
            </section>
          </div>
        </article>
        {{/each}}
      </div>
      {{/if}}

      {{#if isGM}}
      {{#if gmPanelTabOperations}}
      <aside class="po-gm-panel {{#if mainTabOperationsOrGm}}is-operations-full{{/if}}">
        {{#if mainTabOperations}}
        <nav class="po-tabs po-tabs-ops" role="tablist" aria-label="Operations Pages">
          <button type="button" class="po-tab {{#if operationsPagePlanning}}is-active{{/if}}" data-action="operations-page" data-page="planning" title="Track resources and loot operations">Planning</button>
          <button type="button" class="po-tab {{#if operationsPageReputation}}is-active{{/if}}" data-action="operations-page" data-page="reputation" title="Track faction standing and access levels">Reputation</button>
          <button type="button" class="po-tab {{#if operationsPageMerchants}}is-active{{/if}}" data-action="operations-page" data-page="merchants" title="Track merchant contacts, routes, and procurement priorities">Merchants</button>
          <button type="button" class="po-tab {{#if operationsPageRecovery}}is-active{{/if}}" data-action="operations-page" data-page="recovery" title="Track injuries, stabilization, and recovery cycles">Recovery</button>
        </nav>
        {{/if}}

        {{#if mainTabOperations}}

        <div id="po-ops-summary" class="po-gm-section po-gm-section-compact">
          <div class="po-info-strip">
            <div class="po-info-chip" title="Overall operational risk from role coverage and base pressure"><span>Risk</span><strong>{{operations.summary.effects.riskTier}}</strong></div>
            <div class="po-info-chip" title="Estimated number of long-rest cycles before food is depleted"><span>Food Cycles</span><strong>{{operations.resources.summary.foodCyclesLeft}}</strong></div>
            <div class="po-info-chip" title="Estimated number of long-rest cycles before water is depleted"><span>Water Cycles</span><strong>{{operations.resources.summary.waterCyclesLeft}}</strong></div>
            <div class="po-info-chip" title="Inventory bindings linked to owned player-character items"><span>Bindings</span><strong>{{operations.resources.summary.selectedBindingCount}} / 3</strong></div>
          </div>
        </div>

        {{#if operationsPagePlanning}}

        <nav class="po-tabs po-tabs-sub po-planning-tabs" role="tablist" aria-label="Planning Sections">
          <button type="button" class="po-tab {{#if operationsPlanningResources}}is-active{{/if}}" data-action="operations-planning-tab" data-planning-tab="resources" title="Track supplies, drains, and inventory bindings">Resources</button>
          <button type="button" class="po-tab {{#if operationsPlanningLoot}}is-active{{/if}}" data-action="operations-planning-tab" data-planning-tab="loot" title="Assign and collect published loot">Loot</button>
        </nav>

        {{#if operationsPlanningResources}}
        <div id="po-ops-resources" class="po-gm-section">
          <div class="po-section-head-row">
            <div class="po-section-title">Resources</div>
            {{#if @root.isGM}}
            <button
              type="button"
              class="po-btn po-btn-sm po-gather-launch-btn"
              data-action="gather-resource-check"
              title="Call players to choose a PC-owned character for gathering">
              <i class="fa-solid fa-seedling" aria-hidden="true"></i>
              <span class="po-gather-launch-btn-copy">
                <span class="po-gather-launch-btn-main">Call Gather</span>
                <span class="po-gather-launch-btn-sub">Player Requests</span>
              </span>
            </button>
            {{/if}}
          </div>
          <div class="po-hint">Track supply forecasts, shared pools, and target bindings here. Call Gather prompts players to submit PC-owned gathering requests for GM resolution.</div>
          <div class="po-info-strip">
            <div class="po-info-chip" title="Projected food consumed per day"><span>Per Day Food</span><strong>{{operations.resources.summary.foodDrainPerDay}}</strong></div>
            <div class="po-info-chip" title="Steward pool state for food (none, finite stock, or surplus source)"><span>Food Rations</span><strong>{{operations.resources.summary.foodStewardPoolDisplay}}</strong></div>
            <div class="po-info-chip" title="Estimated cycles supported by food rations plus linked food inventory"><span>Food Ration Cycles</span><strong>{{operations.resources.summary.foodRationCyclesLeft}}</strong></div>
            <div class="po-info-chip" title="Projected water consumed per day"><span>Per Day Water</span><strong>{{operations.resources.summary.waterDrainPerDay}}</strong></div>
            <div class="po-info-chip" title="Steward pool state for water (none, finite stock, or surplus source)"><span>Water Rations</span><strong>{{operations.resources.summary.waterStewardPoolDisplay}}</strong></div>
            <div class="po-info-chip" title="Estimated cycles supported by water rations plus linked water inventory"><span>Water Ration Cycles</span><strong>{{operations.resources.summary.waterRationCyclesLeft}}</strong></div>
            <div class="po-info-chip" title="Projected torches consumed per day"><span>Per Day Torches</span><strong>{{operations.resources.summary.torchDrainPerDay}}</strong></div>
          </div>
          <div class="po-info-strip">
            <div class="po-info-chip" title="Calendar days elapsed since last upkeep application"><span>Pending Days</span><strong>{{operations.resources.summary.upkeepDaysPending}}</strong></div>
            <div class="po-info-chip" title="Food expected to be deducted when daily upkeep is applied"><span>Pending Food</span><strong>{{operations.resources.summary.foodDrainPending}}</strong></div>
            <div class="po-info-chip" title="Water expected to be deducted when daily upkeep is applied"><span>Pending Water</span><strong>{{operations.resources.summary.waterDrainPending}}</strong></div>
            <div class="po-info-chip" title="Current automatic upkeep gate state"><span>Auto Upkeep</span><strong>{{operations.resources.summary.autoUpkeepPromptLabel}}</strong></div>
          </div>
          <div class="po-op-summary {{#if operations.resources.gatherFoodCoveredNextUpkeep}}is-good{{else}}{{#if operations.resources.gatherWaterCoveredNextUpkeep}}is-good{{else}}is-warn{{/if}}{{/if}}" title="Gathered food and water are held in a pending pool, consumed by upkeep first, then any remainder is pushed into the configured targets.">
            Pending Gather Pool - Food: {{operations.resources.summary.pendingGatherFood}} - Water: {{operations.resources.summary.pendingGatherWater}}
          </div>
          <div class="po-op-divider"></div>
          <div class="po-hint">Track supply pools and linked target items here. GM-only gather presets, upkeep tuning, DCs, and pending requests now live in the GM workspace.</div>
          <div class="po-resource-config-panel po-resource-config-panel-compact">
            <div class="po-resource-config-split po-resource-config-split-compact">
              <div class="po-resource-config-col">
                <div class="po-section-title">Steward Pools</div>
                <div class="po-hint">Optional surplus in addition to Resource Targets. Use <strong>Surplus Source</strong> for location abundance (river, inn, stocked camp), or <strong>Finite Stock</strong> when a place has a limited extra pool.</div>
                {{#each operations.resources.stewardPools}}
                <div class="po-op-role-row">
                  <div class="po-op-role-head">
                    <div class="po-op-role-name">{{label}}</div>
                    <div class="po-op-role-status">{{amountDisplay}}</div>
                  </div>
                  <label class="po-resource-row">
                    <span>Pool Type</span>
                    <select class="po-select" data-action="set-resource" data-resource="stewardPoolMode:{{key}}">
                      {{#each modeOptions}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label class="po-resource-row">
                    <span>Source / Context</span>
                    <input type="text" class="po-input" data-action="set-resource" data-resource="stewardPoolSource:{{key}}" value="{{source}}" placeholder="e.g., Riverbank camp, Inn kitchen, Guard outpost stores" />
                  </label>
                  {{#if isFinite}}
                  <label class="po-resource-row">
                    <span>Available Stock</span>
                    <input type="number" min="0" step="1" class="po-input" data-action="set-resource" data-resource="stewardPoolAmount:{{key}}" value="{{amount}}" />
                  </label>
                  {{/if}}
                </div>
                {{/each}}
              </div>

              <div class="po-resource-config-col">
                <div class="po-section-title">Resource Targets</div>
                <label class="po-resource-row">
                  <span>Food Owner</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionActor:food">
                    {{#each operations.resources.itemSelections.food.actorOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Food Inventory Item</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionItem:food" {{#unless operations.resources.itemSelections.food.hasActor}}disabled{{/unless}}>
                    {{#each operations.resources.itemSelections.food.itemOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Water Owner</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionActor:water">
                    {{#each operations.resources.itemSelections.water.actorOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Water Inventory Item</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionItem:water" {{#unless operations.resources.itemSelections.water.hasActor}}disabled{{/unless}}>
                    {{#each operations.resources.itemSelections.water.itemOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Torches Owner</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionActor:torches">
                    {{#each operations.resources.itemSelections.torches.actorOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="po-resource-row">
                  <span>Torches Inventory Item</span>
                  <select class="po-select" data-action="set-resource" data-resource="itemSelectionItem:torches" {{#unless operations.resources.itemSelections.torches.hasActor}}disabled{{/unless}}>
                    {{#each operations.resources.itemSelections.torches.itemOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </label>
              </div>
            </div>
          </div>
          <div class="po-op-divider"></div>
          <details class="po-panel-disclosure po-gather-history-disclosure">
            <summary class="po-panel-disclosure-summary">
              <span class="po-section-title">Gather History</span>
              <span class="po-op-summary">Showing {{operations.resources.gatherHistory.visibleCount}} of {{operations.resources.gatherHistory.totalCount}}</span>
            </summary>
            <div class="po-panel-disclosure-body">
              <div class="po-gather-history-head-tools">
                <div class="po-gather-history-head-actions">
                  <button type="button" class="po-btn po-btn-sm" data-action="clear-gather-history-filters">Reset Filters</button>
                  {{#if @root.isGM}}
                  <button type="button" class="po-btn po-btn-sm" data-action="clear-gather-history">Clear History</button>
                  {{/if}}
                </div>
              </div>
            <div class="po-gather-history-controls">
              <label class="po-resource-row is-search">
                <span>Search</span>
                <input
                  type="text"
                  class="po-input"
                  data-action="set-gather-history-filter"
                  data-filter-key="search"
                  value="{{operations.resources.gatherHistory.filters.search}}"
                  placeholder="{{operations.resources.gatherHistory.filters.searchPlaceholder}}" />
              </label>
              <label class="po-resource-row">
                <span>Result</span>
                <select class="po-select" data-action="set-gather-history-filter" data-filter-key="result">
                  {{#each operations.resources.gatherHistory.resultOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="po-resource-row">
                <span>Type</span>
                <select class="po-select" data-action="set-gather-history-filter" data-filter-key="resource">
                  {{#each operations.resources.gatherHistory.resourceOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="po-resource-row">
                <span>Environment</span>
                <select class="po-select" data-action="set-gather-history-filter" data-filter-key="environment">
                  {{#each operations.resources.gatherHistory.environmentOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="po-resource-row">
                <span>Actor</span>
