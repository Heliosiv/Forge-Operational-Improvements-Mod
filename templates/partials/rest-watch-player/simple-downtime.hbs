<section class="po-player-hub-panel po-player-downtime po-downtime-v2 po-downtime-panel" aria-label="Downtime">
  <div class="po-op-role-row">
    <div>
      <h3>Downtime</h3>
      <div class="po-op-summary">{{downtime.publication.statusLabel}}</div>
    </div>
    <span class="po-pill">{{downtime.pendingCount}} pending</span>
  </div>

  {{#if downtime.activeSession.launched}}
    {{#if downtime.player.hasAssignedActors}}
      {{#if downtime.player.hasAvailableCards}}
      <div class="po-list-row">
        <label class="po-field" title="Choose which assigned actor is taking the downtime action.">
          <span>Character</span>
          <select name="downtimeV2ActorId" class="po-select" data-action="refresh-downtime-submit-selection">
            {{#each downtime.player.actorOptions}}
            <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
        </label>
        <label class="po-field" title="Choose one of the action cards the GM opened for this downtime session.">
          <span>Action</span>
          <select name="downtimeV2CardId" class="po-select" data-action="refresh-downtime-submit-selection">
            {{#each downtime.player.availableCards}}
            <option value="{{id}}" {{#if selected}}selected{{/if}}>{{typeLabel}} - {{title}}</option>
            {{/each}}
          </select>
        </label>
        {{#if downtime.player.selectedCard}}
        <div class="po-op-summary"><strong>{{downtime.player.selectedCard.title}}</strong> | {{downtime.player.selectedCard.typeLabel}} | DC {{downtime.player.selectedCard.dc}}</div>
        <div class="po-op-summary">{{downtime.player.selectedCard.prompt}}</div>
        {{/if}}
        <label class="po-field" title="Optional note for the GM about what you are trying to accomplish.">
          <span>Player Note</span>
          <textarea name="downtimeV2Note" rows="3" class="po-input" placeholder="What are you trying to accomplish?">{{downtime.submit.note}}</textarea>
        </label>
        <button type="button" class="po-btn po-btn-sm is-primary" data-action="submit-downtime-v2" title="Rolls the selected action and sends it to the GM for review.">Roll And Submit</button>
      </div>
      {{else}}
      <div class="po-empty">The GM has not selected cards for this downtime session.</div>
      {{/if}}
    {{else}}
    <div class="po-empty">No assigned character is available for this downtime session.</div>
    {{/if}}
  {{else}}
  <div class="po-empty">Waiting for the GM to launch downtime.</div>
  {{/if}}

  {{#if downtime.player.hasAssignedActors}}
  <section>
    <h4>Active Projects</h4>
    {{#each downtime.player.actorOptions}}
      {{#if hasProjects}}
      <div class="po-list">
        {{#each projects}}
        <article class="po-list-row">
          <strong>{{title}}</strong>
          <div class="po-op-summary">{{type}} | {{progress}} / {{target}} | {{status}}</div>
        </article>
        {{/each}}
      </div>
      {{/if}}
    {{/each}}
  </section>
  {{/if}}

  <section>
    <h4>Submitted</h4>
    {{#if downtime.hasSubmissions}}
    <div class="po-list">
      {{#each downtime.pendingSubmissions}}
      <article class="po-list-row">
        <strong>{{cardTitle}}</strong>
        <div class="po-op-summary">{{actorName}} | Roll {{roll.total}} | {{resultDraft.tierLabel}}</div>
      </article>
      {{/each}}
    </div>
    {{else}}
    <div class="po-empty">No submitted downtime awaiting GM review.</div>
    {{/if}}
  </section>

  <section>
    <h4>Delivered Results</h4>
    {{#if downtime.player.hasDeliveredResults}}
    <div class="po-list">
      {{#each downtime.player.deliveredResults}}
      <article class="po-list-row">
        <div class="po-op-role-row">
          <div>
            <strong>{{cardTitle}}</strong>
            <div class="po-op-summary">{{actorName}} | {{resultDraft.summary}}</div>
            <div class="po-op-summary">Progress +{{resultDraft.progress}} | Reward: {{resultDraft.rewardText}}</div>
          </div>
          {{#if canAcknowledge}}
          <button type="button" class="po-btn po-btn-sm" data-action="ack-downtime-v2-result" data-result-id="{{id}}" title="Marks this delivered result as seen.">Acknowledge</button>
          {{/if}}
        </div>
      </article>
      {{/each}}
    </div>
    {{else}}
    <div class="po-empty">No delivered downtime results yet.</div>
    {{/if}}
  </section>
</section>
