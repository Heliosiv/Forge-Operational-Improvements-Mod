<section id="po-player-hub-panel-downtime" class="po-player-hub-panel po-downtime-panel" role="tabpanel" aria-label="Downtime">
  <div class="po-section-title">Submit Downtime Action</div>
  <div class="po-downtime-status-strip" aria-label="Downtime publication summary">
    <div class="po-downtime-status-card">
      <span class="po-downtime-status-label">Status</span>
      <strong class="po-downtime-status-value">{{downtime.publication.statusLabel}}</strong>
    </div>
    <div class="po-downtime-status-card {{#if downtime.submit.canSubmit}}is-ready{{else}}is-blocked{{/if}}">
      <span class="po-downtime-status-label">Ready</span>
      <strong class="po-downtime-status-value">{{#if downtime.submit.canSubmit}}Yes{{else}}No{{/if}}</strong>
    </div>
    <div class="po-downtime-status-card po-downtime-status-card-wide">
      <span class="po-downtime-status-label">Selection</span>
      <strong class="po-downtime-status-value">{{#each downtime.submit.actionOptions}}{{#if selected}}{{label}}{{/if}}{{/each}} for {{downtime.submit.hours}} hour(s)</strong>
    </div>
  </div>
  <details class="po-panel-disclosure po-downtime-status-details">
    <summary class="po-panel-disclosure-summary">
      <span class="po-section-title">Publication Details</span>
      <span class="po-op-summary">Published {{downtime.publication.publishedAtLabel}} by {{downtime.publication.publishedBy}}</span>
    </summary>
    <div class="po-panel-disclosure-body">
      <div class="po-hint">{{downtime.publication.submitHint}}</div>
      <div class="po-op-summary" aria-live="polite">Submitting or refreshing may take a moment while the GM ledger updates.</div>
    </div>
  </details>
  {{#if downtime.submit.canSubmit}}
  {{#if downtime.submit.canChooseActor}}
  <label class="po-resource-row">
    <span>Actor</span>
    <select name="downtimeActorId" class="po-select" data-action="refresh-downtime-submit-selection">
      {{#each downtime.submit.actorOptions}}
      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
      {{/each}}
    </select>
  </label>
  {{else}}
  <div class="po-op-summary"><strong>Actor:</strong> {{downtime.submit.actorName}}</div>
  {{/if}}
  <label class="po-resource-row">
    <span>Action</span>
    <select name="downtimeActionKey" class="po-select" data-action="refresh-downtime-submit-selection">
      {{#each downtime.submit.actionOptions}}
      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </label>
  {{#if downtime.submit.showSubtypeFields}}
  <label class="po-resource-row">
    <span>Subtype</span>
    <select name="downtimeSubtypeKey" class="po-select" data-action="refresh-downtime-submit-selection">
      {{#each downtime.submit.subtypeOptions}}
      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </label>
  {{#if downtime.submit.selectedSubtype.guidance}}
  <div class="po-op-summary">{{downtime.submit.selectedSubtype.guidance}}</div>
  {{/if}}
  {{/if}}
  <label class="po-resource-row">
    <span>Hours</span>
    <input name="downtimeHours" type="number" min="1" max="{{downtime.submit.hoursMax}}" step="1" class="po-input" value="{{downtime.submit.hours}}" />
  </label>
  <label class="po-resource-row po-notes-row-lg">
    <span>Note</span>
    <textarea name="downtimeNote" rows="3" class="po-input" placeholder="Optional context for your GM">{{downtime.submit.note}}</textarea>
  </label>
  <div class="po-op-summary"><strong>Area Settings:</strong> {{downtime.submit.areaSettingsLabel}}</div>
  <div class="po-op-summary"><strong>Stored Effects:</strong> {{downtime.submit.activeRewardEffectsSummary}}</div>
  {{#if downtime.submit.showBrowsingFields}}
  <label class="po-resource-row">
    <span>Browsing Ability</span>
    <select name="downtimeBrowsingAbility" class="po-select" data-action="refresh-downtime-submit-selection">
      {{#each downtime.submit.browsingAbilityOptions}}
      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </label>
  {{/if}}
  {{#if downtime.submit.showCraftingFields}}
  <label class="po-resource-row">
    <span>Craft Item</span>
    <select name="downtimeCraftItemId" class="po-select" data-action="refresh-downtime-submit-selection">
      <option value="">Select craftable item</option>
      {{#each downtime.submit.craftingCategoryViews}}
      <optgroup label="{{label}}">
        {{#each items}}
        <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </optgroup>
      {{/each}}
    </select>
  </label>
  {{#unless downtime.submit.hasCraftingOptions}}
  <div class="po-op-summary">No craftable items match this actor's tool proficiencies.</div>
  {{/unless}}
  {{#if downtime.submit.hasSelectedCraftable}}
  <div class="po-op-summary">Crafting: {{downtime.submit.selectedCraftableName}} | Tool {{downtime.submit.selectedCraftableTool}} | Materials {{downtime.submit.selectedCraftableMaterialCost}} gp | Progress {{downtime.submit.selectedCraftableProgressRequired}}</div>
  {{#if downtime.submit.hasCraftingProject}}
  <div class="po-op-summary">Existing project progress: {{downtime.submit.craftingProjectProgressLabel}}</div>
  {{/if}}
  {{/if}}
  <label class="po-resource-row">
    <span>Materials</span>
    <select name="downtimeCraftMaterialsOwned" class="po-select" data-action="refresh-downtime-submit-selection">
      {{#each downtime.submit.materialsOwnedOptions}}
      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </label>
  {{#if downtime.submit.showMaterialDropZone}}
  <label class="po-resource-row po-notes-row-lg">
    <span>Materials On Hand</span>
    <input type="hidden" name="downtimeCraftMaterialDrops" value="{{downtime.submit.materialDropsJson}}" />
    <div class="po-loot-preview-dropzone" data-downtime-material-dropzone>Drop the material items you want the GM to review for this project.</div>
    <div class="po-loot-preview-items-grid" data-downtime-material-drop-list>
      {{#if downtime.submit.hasMaterialDrops}}
      {{#each downtime.submit.materialDrops}}
      <div class="po-op-role-row">
        <div class="po-op-role-head">
          <div class="po-op-role-name"><img src="{{img}}" width="18" height="18" /> {{name}}</div>
          <div class="po-op-role-status">x{{quantity}}</div>
        </div>
        <div class="po-op-summary">{{#if uuid}}{{uuid}}{{else}}World Item / Snapshot{{/if}}</div>
        <div class="po-op-action-row">
          <button type="button" class="po-btn po-btn-sm is-danger" data-action="remove-downtime-material-drop" data-drop-id="{{id}}">Remove</button>
        </div>
      </div>
      {{/each}}
      {{else}}
      <div class="po-op-summary">No materials selected.</div>
      {{/if}}
    </div>
  </label>
  <div class="po-hint">The GM decides how much of these materials count and any extra gp due when the result is collected.</div>
  {{/if}}
  {{/if}}
  {{#if downtime.submit.showCraftingFields}}
  <details class="po-panel-disclosure">
    <summary class="po-panel-disclosure-summary">
      <span class="po-section-title">Crafting Catalog</span>
      <span class="po-op-summary">Expandable baseline catalog</span>
    </summary>
    <div class="po-panel-disclosure-body">
      {{#each downtime.submit.craftingCatalogCategoryViews}}
      <details class="po-panel-disclosure">
        <summary class="po-panel-disclosure-summary">
          <span class="po-section-title">{{label}}</span>
          <span class="po-op-summary">{{itemCount}} items</span>
        </summary>
        <div class="po-panel-disclosure-body">
          {{#each items}}
          <div class="po-op-summary">{{name}} | {{requiredToolProficiency}} | Cost {{materialCost}}/{{baseCost}} gp | Progress {{progressRequired}}</div>
          {{/each}}
        </div>
      </details>
      {{/each}}
    </div>
  </details>
  {{/if}}
  {{#if downtime.submit.showProfessionFields}}
  <label class="po-resource-row">
    <span>Profession</span>
    <select name="downtimeProfessionId" class="po-select" data-action="refresh-downtime-submit-selection">
      <option value="">Select profession</option>
      {{#each downtime.submit.professionOptions}}
      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}{{#if known}} [Known]{{/if}}</option>
      {{/each}}
    </select>
  </label>
  {{#unless downtime.submit.hasProfessionOptions}}
  <div class="po-op-summary">No professions are available for this actor.</div>
  {{/unless}}
  {{#if downtime.submit.hasKnownProfessionNames}}
  <div class="po-op-summary">Known professions: {{#each downtime.submit.knownProfessionNames}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
  {{/if}}
  {{/if}}
  <div class="po-op-action-row">
    <button type="button" class="po-btn po-btn-sm is-primary" data-action="submit-downtime-action">Submit Downtime Action</button>
  </div>
  {{else}}
  <div class="po-op-summary">{{downtime.submit.disabledReason}}</div>
  {{/if}}
  <div class="po-op-divider"></div>
  <div class="po-section-title">Current Entries</div>
  {{#if downtime.hasEntries}}
  {{#each downtime.entries}}
  <div class="po-op-role-row">
    <div class="po-op-role-head">
      <div class="po-op-role-name">{{actorName}}</div>
      <div class="po-op-role-status {{#if pending}}is-warn{{else}}is-ready{{/if}}">{{statusLabel}}</div>
    </div>
    <div class="po-op-summary">{{actionLabel}} - {{hours}} hour(s)</div>
      {{#if hasQueuedEntries}}
      <div class="po-op-summary">Queued: {{queueSummaryLabel}}</div>
      {{#each queuedPreview}}
      <div class="po-op-summary">- {{this}}</div>
      {{/each}}
      {{/if}}
    {{#if hasActionDetails}}
    {{#each actionDetails}}
    <div class="po-op-summary">{{this}}</div>
    {{/each}}
    {{/if}}
    {{#if hasNote}}<div class="po-op-summary">Note: {{note}}</div>{{/if}}
    {{#if hasResult}}
    <details class="po-panel-disclosure">
      <summary class="po-panel-disclosure-summary">
        <span class="po-section-title">Result: {{resultSummary}}</span>
        <span class="po-op-summary">{{#if resultTierLabel}}Tier {{resultTierLabel}}{{else}}Details{{/if}}</span>
      </summary>
      <div class="po-panel-disclosure-body">
        {{#if resultTierLabel}}<div class="po-op-summary">Tier: {{resultTierLabel}}</div>{{/if}}
        {{#if hasExpectedQuality}}<div class="po-op-summary">Expected Quality: {{expectedQuality}}</div>{{/if}}
        {{#if hasSuggestedTags}}<div class="po-op-summary">Suggested Tags: {{#each suggestedTags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>{{/if}}
        {{#if hasRewardTags}}<div class="po-op-summary">Reward Tags: {{#each rewardTags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>{{/if}}
        {{#if hasRewardEffects}}
        <div class="po-op-summary">Reward Effects:{{#if rewardEffects.discountPercent}} Discount {{rewardEffects.discountPercent}}%{{/if}}{{#if rewardEffects.materialsCreditGp}} | Materials Credit {{rewardEffects.materialsCreditGp}} gp{{/if}}{{#if rewardEffects.heatDelta}} | Heat +{{rewardEffects.heatDelta}}{{/if}}{{#if rewardEffects.contactTier}} | Contact {{rewardEffects.contactTier}}{{/if}}{{#if rewardEffects.reputationDelta}} | Reputation {{rewardEffects.reputationDelta}}{{/if}}</div>
        {{/if}}
        {{#if hasPerformanceLabel}}<div class="po-op-summary">Performance: {{performanceLabel}}</div>{{/if}}
        {{#if hasCraftingStatus}}<div class="po-op-summary">{{craftingStatus}}</div>{{/if}}
      </div>
    </details>
    {{#if canCollect}}
    <button type="button" class="po-btn po-btn-sm" data-action="collect-downtime-result" data-actor-id="{{actorId}}">Collect Result</button>
    {{/if}}
    {{/if}}
    <div class="po-op-summary">Updated: {{updatedAtLabel}} by {{updatedBy}}</div>
  </div>
  {{/each}}
  {{else}}
  <div class="po-op-summary">No downtime entries yet.</div>
  {{/if}}
</section>
