<section id="po-player-hub-panel-march" class="po-player-hub-panel" role="tabpanel" aria-label="March">
  <div class="po-player-hub-panel-head">
    <div>
      <div class="po-section-title">Marching Position</div>
      <div class="po-hint">Set your rank here. Open the full marching order only when you need the whole formation view.</div>
    </div>
    <span class="po-pill">{{playerMarch.lockState}}</span>
  </div>
  {{#if playerMarch.hasActor}}
  <section class="po-player-hub-focus-card" aria-label="Current marching position">
    <div>
      <span>Character</span>
      <strong>{{playerMarch.actorName}}</strong>
    </div>
    <div>
      <span>Current Rank</span>
      <strong>{{playerMarch.currentRankLabel}}</strong>
    </div>
  </section>
  <div class="po-op-action-row po-player-march-actions" aria-label="Move to rank">
    {{#each playerMarch.rankButtons}}
    <button type="button" class="po-btn po-btn-sm {{#if selected}}is-primary{{/if}}" data-action="set-player-rank" data-rank-id="{{id}}" {{#unless @root.playerMarch.canSetRank}}disabled{{/unless}}>Move to {{label}}</button>
    {{/each}}
  </div>
  {{else}}
  <div class="po-op-summary is-warn">No active character found for this user.</div>
  {{/if}}
  <div class="po-op-action-row">
    <button type="button" class="po-btn po-btn-sm" data-action="switch-tab" data-tab="march">Open Full Formation</button>
  </div>
</section>
